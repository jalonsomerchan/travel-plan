{
  "name": "astro-template",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "node --test tests/*.test.mjs",
    "format": "npx --yes prettier@latest --write \"**/*.{css,js,json,md,mjs,ts,yml,yaml}\"",
    "format:check": "npx --yes prettier@latest --check \"**/*.{css,js,json,md,mjs,ts,yml,yaml}\"",
    "clean": "node scripts/clean.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.1",
    "astro-icon": "^1.1.5",
    "astro-seo": "^1.1.0",
    "expressive-code": "^0.42.0",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  }
}
