rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userEmailLower() {
      return lower(request.auth.token.email);
    }

    function tripVisibleFromResource() {
      return tripVisibleFromTripData(resource.data);
    }

    function tripDirectlyVisibleFromTripData(tripData) {
      return signedIn() && (
        tripData.ownerId == request.auth.uid ||
        request.auth.uid in tripData.memberIds
      );
    }

    function tripVisibleFromTripData(tripData) {
      return tripDirectlyVisibleFromTripData(tripData) || (
        tripData.parentTripId is string &&
        tripDirectlyVisibleFromTripData(
          get(/databases/$(database)/documents/trips/$(tripData.parentTripId)).data
        )
      );
    }

    function tripVisibleFromParent(tripId) {
      return tripVisibleFromTripData(
        get(/databases/$(database)/documents/trips/$(tripId)).data
      );
    }

    function tripOwnedByCurrentUser(tripId) {
      return signedIn() &&
        get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid;
    }

    function pendingInviteForCurrentUser(tripId) {
      return signedIn() && exists(
        /databases/$(database)/documents/userInvites/$(userEmailLower())/invites/$(tripId + '_' + userEmailLower())
      ) && get(
        /databases/$(database)/documents/userInvites/$(userEmailLower())/invites/$(tripId + '_' + userEmailLower())
      ).data.status == 'pending';
    }

    function recipientMemberCreatable(tripId, memberId) {
      return pendingInviteForCurrentUser(tripId) &&
        memberId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        lower(request.resource.data.email) == userEmailLower();
    }

    function recipientTripAcceptanceUpdate() {
      return signedIn() &&
        !(request.auth.uid in resource.data.memberIds) &&
        request.auth.uid in request.resource.data.memberIds &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'updatedAt']);
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /trips/{tripId} {
      allow read: if tripVisibleFromResource() || pendingInviteForCurrentUser(tripId);

      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.auth.uid in request.resource.data.memberIds &&
        (
          !(request.resource.data.parentTripId is string) ||
          tripVisibleFromParent(request.resource.data.parentTripId)
        );

      allow update: if tripVisibleFromResource() ||
        pendingInviteForCurrentUser(tripId) ||
        recipientTripAcceptanceUpdate();

      match /members/{memberId} {
        /*
          TEMPORAL:
          Permisivo mientras se estabiliza la aceptación de invitaciones.
          El invitado necesita crear su documento de miembro antes de que
          `request.auth.uid` exista en `memberIds`.
        */
        allow read, create: if signedIn();
        allow update, delete: if tripVisibleFromParent(tripId);
      }

      match /plans/{planId} {
        allow read, write: if tripVisibleFromParent(tripId);
      }

      match /checklistItems/{checklistItemId} {
        allow read, write: if tripVisibleFromParent(tripId);
      }

      match /pointsOfInterest/{pointId} {
        allow read, write: if tripVisibleFromParent(tripId);
      }

      match /luggageItems/{luggageItemId} {
        allow read: if tripVisibleFromParent(tripId) &&
          resource.data.ownerId == request.auth.uid;
        allow create: if tripVisibleFromParent(tripId) &&
          request.resource.data.ownerId == request.auth.uid;
        allow update: if tripVisibleFromParent(tripId) &&
          resource.data.ownerId == request.auth.uid &&
          request.resource.data.ownerId == request.auth.uid;
        allow delete: if tripVisibleFromParent(tripId) &&
          resource.data.ownerId == request.auth.uid;
      }
    }

    /*
      TEMPORAL:
      Reglas abiertas para invitaciones mientras estabilizamos el flujo.
      Esto desbloquea:
      - queries antiguas a tripInvites
      - lecturas a userInvites/{email}
      - lecturas a userInvites/{email}/invites
      - escrituras de invitación desde cliente
      Cuando el flujo esté estable, conviene endurecer estas reglas.
    */
    match /tripInvites/{inviteId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.tripId is string &&
        request.resource.data.emailLower is string &&
        request.resource.data.status == 'pending' &&
        tripOwnedByCurrentUser(request.resource.data.tripId);
      allow update: if signedIn();
      allow delete: if false;
    }

    match /userInvites/{emailLower} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;

      match /invites/{inviteId} {
        allow read: if signedIn();
        allow create, update: if signedIn();
        allow delete: if false;
      }
    }

    match /mail/{mailId} {
      allow read, update, delete: if false;

      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.tripId is string &&
        request.resource.data.to is string &&
        request.resource.data.message.subject is string &&
        request.resource.data.message.text is string &&
        request.resource.data.message.html is string &&
        tripOwnedByCurrentUser(request.resource.data.tripId);
    }
  }
}