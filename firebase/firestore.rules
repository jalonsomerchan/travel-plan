rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userEmailLower() {
      return lower(request.auth.token.email);
    }

    function tripVisibleFromResource() {
      return signedIn() && request.auth.uid in resource.data.memberIds;
    }

    function tripVisibleFromTripData(tripData) {
      return signedIn() && request.auth.uid in tripData.memberIds;
    }

    function tripVisibleFromParent(tripId) {
      return tripVisibleFromTripData(
        get(/databases/$(database)/documents/trips/$(tripId)).data
      );
    }

    function tripOwnedByCurrentUser(tripId) {
      return signedIn() &&
        get(/databases/$(database)/documents/trips/$(tripId)).data.ownerId == request.auth.uid;
    }

    function tripInviteReadable() {
      return signedIn() && (
        resource.data.ownerId == request.auth.uid ||
        userEmailLower() == resource.data.emailLower
      );
    }

    function tripInviteCreatable() {
      return signedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.tripId is string &&
        request.resource.data.emailLower is string &&
        request.resource.data.status == 'pending' &&
        tripOwnedByCurrentUser(request.resource.data.tripId);
    }

    function recipientInviteAccessible(emailLower) {
      return signedIn() && userEmailLower() == emailLower;
    }

    function recipientInviteWritable(emailLower) {
      return signedIn() && (
        userEmailLower() == emailLower ||
        (
          request.resource.data.ownerId == request.auth.uid &&
          request.resource.data.emailLower == emailLower &&
          request.resource.data.tripId is string &&
          tripOwnedByCurrentUser(request.resource.data.tripId)
        )
      );
    }

    match /users/{userId} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    match /trips/{tripId} {
      allow read: if tripVisibleFromResource();
      allow create: if signedIn() &&
        request.resource.data.ownerId == request.auth.uid &&
        tripVisibleFromTripData(request.resource.data);
      allow update: if tripVisibleFromResource();

      match /members/{memberId} {
        allow read, write: if tripVisibleFromParent(tripId);
      }

      match /plans/{planId} {
        allow read, write: if tripVisibleFromParent(tripId);
      }

      match /checklistItems/{checklistItemId} {
        allow read, write: if tripVisibleFromParent(tripId);
      }

      match /luggageItems/{luggageItemId} {
        allow read, write: if tripOwnedByCurrentUser(tripId);
      }
    }

    match /tripInvites/{inviteId} {
      allow read: if tripInviteReadable();
      allow create: if tripInviteCreatable();
      allow update: if tripInviteReadable();
    }

    match /userInvites/{emailLower}/invites/{inviteId} {
      allow read: if recipientInviteAccessible(emailLower);
      allow create, update: if recipientInviteWritable(emailLower);
      allow delete: if false;
    }
  }
}
