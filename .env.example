# GitHub Pages custom domain for production.
ASTRO_SITE=https://travelplan.alon.one

# Use / for the custom domain or /travel-plan for subfolder previews.
ASTRO_BASE=/

# Override the repository link shown in the UI.
PUBLIC_REPOSITORY_URL=https://github.com/jorgealonso/travel-plan

# Firebase public client config.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=
