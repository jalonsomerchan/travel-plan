---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../Container.astro';
import { siteConfig, type Locale } from '../../config/site';
import {
  getPublicPage,
  getPublicPagePath,
  getPublicPages,
  type PublicPageId,
} from '../../data/public-pages';
import { getPublicPageUi } from '../../data/public-page-ui';
import { getLocalizedPath } from '../../i18n/ui';
import { getAbsoluteUrl } from '../../utils/paths';

interface Props {
  id: PublicPageId;
  locale: Locale;
}

const { id, locale } = Astro.props;
const page = getPublicPage(locale, id);
const pages = getPublicPages(locale);
const ui = getPublicPageUi(locale);
const pageUrl = getAbsoluteUrl(getLocalizedPath(getPublicPagePath(locale, page.id), locale), siteConfig.url);
const pageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: page.title,
  description: page.description,
  url: pageUrl,
  inLanguage: locale,
  isPartOf: {
    '@type': 'WebSite',
    name: siteConfig.name,
    url: siteConfig.url,
  },
  mainEntity: page.sections.map((section) => ({
    '@type': 'Question',
    name: section.title,
    acceptedAnswer: {
      '@type': 'Answer',
      text: [section.body, ...(section.items ?? [])].join(' '),
    },
  })),
};
---

<BaseLayout title={page.title} description={page.description} locale={locale}>
  <Container class="py-10 md:py-16">
    <article class="section-shell px-6 py-8 md:px-10 md:py-12">
      <nav aria-label={ui.navLabel} class="mb-8 flex flex-wrap gap-2 text-sm">
        {pages.map((item) => (
          <a
            class="rounded-full border border-[var(--color-border)] px-3 py-2 font-semibold text-[var(--color-text-muted)] transition hover:border-[var(--color-border-strong)] hover:bg-[var(--color-surface-soft)] hover:text-[var(--color-text)]"
            href={getLocalizedPath(getPublicPagePath(locale, item.id), locale)}
            aria-current={item.id === page.id ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <header class="max-w-3xl">
        <p class="text-sm font-bold uppercase tracking-[0.18em] text-[var(--color-primary)]">{page.eyebrow}</p>
        <h1 class="mt-3 text-4xl font-black tracking-tight text-[var(--color-text)] md:text-5xl">
          {page.title}
        </h1>
        <p class="prose-copy mt-5 text-lg md:text-xl">{page.intro}</p>
      </header>

      <div class="mt-10 grid gap-6">
        {page.sections.map((section) => (
          <section class="border-t border-[var(--color-border)] pt-6">
            <h2 class="text-2xl font-black tracking-tight text-[var(--color-text)]">{section.title}</h2>
            <p class="prose-copy mt-3">{section.body}</p>
            {section.items && (
              <ul class="mt-4 grid gap-2 text-sm text-[var(--color-text-muted)]">
                {section.items.map((item) => (
                  <li class="flex gap-2">
                    <span aria-hidden="true" class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--color-primary)]"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            )}
          </section>
        ))}
      </div>

      <footer class="mt-10 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-5">
        <h2 class="text-xl font-black text-[var(--color-text)]">{ui.ctaTitle}</h2>
        <p class="prose-copy mt-2 text-sm">{ui.ctaDescription}</p>
        <a class="app-card-link mt-4 inline-flex" data-variant="primary" href={getLocalizedPath('/app/', locale)}>
          {ui.ctaAction}
        </a>
      </footer>
    </article>
  </Container>
  <script type="application/ld+json" set:html={JSON.stringify(pageJsonLd)}></script>
</BaseLayout>
