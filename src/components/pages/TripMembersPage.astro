---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import LoadingState from '../app/LoadingState.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import TripSectionNav from '../app/TripSectionNav.astro';
import Button from '../Button.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';
import { tripMemberRoles } from '../../lib/app/models';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('tripMembers.metaTitle')} description={t('tripMembers.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('tripMembers.eyebrow')}
    title={t('tripMembers.title')}
    description={t('tripMembers.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('tripMembers.breadcrumb') },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <TripSectionNav slot="nav" locale={locale} fallbackHref={dashboardUrl} />
    <div slot="body" class="mt-8 border-t border-[var(--color-border)] pt-6">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="min-w-0">
          <h2 class="text-2xl font-black" data-trip-context>{t('trip.membersTitle')}</h2>
          <form class="mt-6 grid gap-4 md:grid-cols-[1fr_auto_auto]" id="invite-form">
            <div>
              <label class="field-label" for="invite-email">{t('trip.invite.email')}</label>
              <input class="field-input" id="invite-email" name="email" type="email" required />
            </div>
            <div>
              <label class="field-label" for="invite-role">{t('trip.invite.role')}</label>
              <select class="field-select" id="invite-role" name="role">
                {tripMemberRoles.map((role) => (
                  <option value={role}>{t(`role.${role}`)}</option>
                ))}
              </select>
            </div>
            <div class="flex items-end gap-3">
              <Button class="w-full md:w-auto" type="submit">{t('trip.invite.action')}</Button>
              <Button class="w-full md:w-auto" id="invite-share-button" type="button" variant="secondary">{t('trip.invite.shareAction')}</Button>
            </div>
          </form>
          <p class="mt-4 text-sm text-[var(--color-text-soft)]" id="invite-message" role="status" aria-live="polite">{t('trip.invite.helper')}</p>
        </div>
        <div class="min-w-0 border-t border-[var(--color-border)] pt-8 lg:border-t-0 lg:border-l lg:pl-8 lg:pt-0">
          <div class="grid gap-4" data-member-list>
            <LoadingState label={t('common.loading')} />
          </div>
        </div>
      </div>
    </div>
  </AppShell>
  <script>
    import { mountTripMembersPage } from '../../scripts/pages/trip-members';

    mountTripMembersPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
