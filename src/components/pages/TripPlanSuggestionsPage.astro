---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import Button from '../Button.astro';
import LocationPickerFields from '../app/LocationPickerFields.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import TripSectionNav from '../app/TripSectionNav.astro';
import { planCategoryValues } from '../../lib/app/models';
import { tripSuggestionBudgetValues, tripSuggestionTransportValues } from '../../lib/app/trip-plan-suggestions';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('tripAi.metaTitle')} description={t('tripAi.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('tripAi.eyebrow')}
    title={t('tripAi.title')}
    description={t('tripAi.description')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('tripAi.breadcrumb') },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <TripSectionNav slot="nav" locale={locale} fallbackHref={dashboardUrl} />
    <div slot="body" class="mt-8 border-t border-[var(--color-border)] pt-6">
      <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <span class="eyebrow">{t('tripAi.form.eyebrow')}</span>
            <h2 class="mt-3 text-2xl font-black text-[var(--color-text)]" data-trip-ai-context>
              {t('tripAi.form.title')}
            </h2>
            <p class="mt-3 text-sm font-semibold text-[var(--color-text-soft)]" data-trip-ai-step-progress>
              {t('tripAi.form.stepProgress').replace('{current}', '1').replace('{total}', '6')}
            </p>
          </div>
          <span class="status-pill" data-tone="primary">{t('tripAi.form.badge')}</span>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2 xl:grid-cols-6">
          {[
            t('tripAi.form.baseLocation'),
            t('tripAi.form.radius'),
            t('tripAi.form.transport'),
            t('tripAi.form.budget'),
            t('tripAi.form.types'),
            t('tripAi.form.datesQuestion'),
          ].map((label, index) => (
            <article
              class="wizard-step-chip"
              data-step-chip
              data-step-chip-index={String(index)}
              data-active={index === 0 ? 'true' : 'false'}
            >
              <span class="wizard-step-chip-index">{index + 1}</span>
              <strong class="wizard-step-chip-label">{label}</strong>
            </article>
          ))}
        </div>

        <form class="mt-6 space-y-5" id="trip-ai-form">
          <section class="space-y-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-5 md:p-6" data-trip-ai-step="0">
            <div>
              <span class="eyebrow">{t('tripAi.form.stepLabel').replace('{number}', '1')}</span>
              <h3 class="mt-3 text-xl font-black text-[var(--color-text)]">{t('tripAi.form.baseLocationQuestion')}</h3>
              <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripAi.form.baseLocationHint')}</p>
            </div>
            <div>
              <LocationPickerFields
                clearButtonName={t('tripAi.form.baseLocationClear')}
                helperKey="tripAi.form.baseLocationMapHint"
                latFieldName="baseLocationLat"
                locale={locale}
                lngFieldName="baseLocationLng"
                nameFieldName="baseLocationName"
                prefix="trip-ai-base-location"
                queryFieldLabel={t('tripAi.form.baseLocation')}
                queryFieldName="baseLocationQuery"
                queryPlaceholder={t('tripAi.form.baseLocationPlaceholder')}
                searchButtonName={t('tripAi.form.baseLocationSearch')}
              />
            </div>
          </section>

          <section class="space-y-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-5 md:p-6" data-trip-ai-step="1" hidden>
            <div>
              <span class="eyebrow">{t('tripAi.form.stepLabel').replace('{number}', '2')}</span>
              <h3 class="mt-3 text-xl font-black text-[var(--color-text)]">{t('tripAi.form.radiusQuestion')}</h3>
              <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripAi.form.radiusHint')}</p>
            </div>
            <div>
              <label class="field-label" for="trip-ai-radius">{t('tripAi.form.radius')}</label>
              <input
                class="field-input"
                id="trip-ai-radius"
                max="300"
                min="1"
                name="radiusKm"
                required
                step="1"
                type="number"
                value="25"
              />
            </div>
          </section>

          <section class="space-y-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-5 md:p-6" data-trip-ai-step="2" hidden>
            <div>
              <span class="eyebrow">{t('tripAi.form.stepLabel').replace('{number}', '3')}</span>
              <h3 class="mt-3 text-xl font-black text-[var(--color-text)]">{t('tripAi.form.transportQuestion')}</h3>
              <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripAi.form.transportHint')}</p>
            </div>
            <div>
              <label class="field-label" for="trip-ai-transport">{t('tripAi.form.transport')}</label>
              <select class="field-select" id="trip-ai-transport" name="transportMode">
                {tripSuggestionTransportValues.map((transport) => (
                  <option value={transport}>{transport ? t(`tripAi.transport.${transport}`) : ''}</option>
                ))}
              </select>
            </div>
          </section>

          <section class="space-y-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-5 md:p-6" data-trip-ai-step="3" hidden>
            <div>
              <span class="eyebrow">{t('tripAi.form.stepLabel').replace('{number}', '4')}</span>
              <h3 class="mt-3 text-xl font-black text-[var(--color-text)]">{t('tripAi.form.budgetQuestion')}</h3>
              <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripAi.form.budgetHint')}</p>
            </div>
            <div>
              <label class="field-label" for="trip-ai-budget">{t('tripAi.form.budget')}</label>
              <select class="field-select" id="trip-ai-budget" name="budgetMode">
                {tripSuggestionBudgetValues.map((budget) => (
                  <option value={budget}>{t(`tripAi.budget.${budget}`)}</option>
                ))}
              </select>
            </div>
          </section>

          <section class="space-y-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-5 md:p-6" data-trip-ai-step="4" hidden>
            <div>
              <span class="eyebrow">{t('tripAi.form.stepLabel').replace('{number}', '5')}</span>
              <h3 class="mt-3 text-xl font-black text-[var(--color-text)]">{t('tripAi.form.typesQuestion')}</h3>
              <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripAi.form.typesHint')}</p>
            </div>
            <div>
              <span class="field-label">{t('tripAi.form.types')}</span>
              <div class="mt-3 grid gap-3 sm:grid-cols-2">
                {planCategoryValues.map((category) => (
                  <label class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-3 text-sm text-[var(--color-text)]">
                    <span class="flex items-start gap-3">
                      <input checked name="types" type="checkbox" value={category} />
                      <span>
                        <strong class="font-semibold">{t(`category.${category}`)}</strong>
                        <span class="mt-1 block text-[var(--color-text-soft)]">
                          {t(`tripAi.typeHint.${category}`)}
                        </span>
                      </span>
                    </span>
                  </label>
                ))}
              </div>
            </div>
          </section>

          <section class="space-y-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-5 md:p-6" data-trip-ai-step="5" hidden>
            <div>
              <span class="eyebrow">{t('tripAi.form.stepLabel').replace('{number}', '6')}</span>
              <h3 class="mt-3 text-xl font-black text-[var(--color-text)]">{t('tripAi.form.datesQuestion')}</h3>
              <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripAi.form.datesHint')}</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <label class="field-label" for="trip-ai-start-date">{t('tripAi.form.startDate')}</label>
                <input class="field-input" id="trip-ai-start-date" name="startDate" required type="date" />
              </div>
              <div>
                <label class="field-label" for="trip-ai-end-date">{t('tripAi.form.endDate')}</label>
                <input class="field-input" id="trip-ai-end-date" name="endDate" required type="date" />
              </div>
            </div>
          </section>

          <p class="text-sm text-[var(--color-text-soft)]" id="trip-ai-form-message">{t('tripAi.form.helper')}</p>
          <div class="grid gap-3 sm:grid-cols-2">
            <Button id="trip-ai-prev-step" type="button" variant="ghost">{t('tripAi.form.previous')}</Button>
            <Button id="trip-ai-next-step" type="button" variant="secondary">{t('tripAi.form.next')}</Button>
            <Button id="trip-ai-submit" type="submit" hidden>{t('tripAi.form.submit')}</Button>
          </div>
        </form>

        <div class="mt-8 border-t border-[var(--color-border)] pt-8">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <span class="eyebrow">{t('tripAi.results.eyebrow')}</span>
            <h2 class="mt-3 text-2xl font-black text-[var(--color-text)]">{t('tripAi.results.title')}</h2>
          </div>
          <span class="status-pill" data-results-count data-tone="warning">0</span>
        </div>

        <p class="mt-3 text-sm text-[var(--color-text-soft)]" data-trip-ai-results-message>
          {t('tripAi.results.idle')}
        </p>
        <div class="mt-5" data-trip-ai-results-loading hidden>
          <div class="flex min-h-32 items-center justify-center rounded-[var(--radius-lg)] border border-dashed border-[var(--color-border)] bg-[var(--color-surface-soft)] px-5 py-8 text-center">
            <span
              aria-hidden="true"
              class="size-9 animate-spin rounded-full border-4 border-[var(--color-border-strong)] border-t-[var(--color-primary)]"
            ></span>
            <span class="sr-only">{t('tripAi.results.loading')}</span>
          </div>
        </div>
        <div class="mt-5 grid gap-4" data-trip-ai-results-list></div>
        <div class="mt-5 flex flex-wrap gap-3" data-trip-ai-results-actions hidden>
          <Button id="trip-ai-load-more" type="button" variant="secondary">{t('tripAi.results.loadMore')}</Button>
        </div>
        </div>
    </div>
  </AppShell>

  <script>
    import { mountTripPlanSuggestionsPage } from '../../scripts/pages/trip-plan-suggestions';

    mountTripPlanSuggestionsPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
