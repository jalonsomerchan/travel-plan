---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import TripSectionNav from '../app/TripSectionNav.astro';
import Button from '../Button.astro';
import PlanFormFields from '../app/PlanFormFields.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('planEdit.metaTitle')} description={t('planEdit.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('planEdit.eyebrow')}
    title={t('planEdit.title')}
    description={t('planEdit.description')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('plan.breadcrumb'), key: 'plan' },
      { label: t('planEdit.breadcrumb') },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <TripSectionNav slot="nav" locale={locale} fallbackHref={dashboardUrl} />
    <div slot="body" class="mt-8 border-t border-[var(--color-border)] pt-6">
      <h2 class="text-2xl font-black" data-plan-context>{t('plan.detailsTitle')}</h2>
      <form class="mx-auto mt-6 max-w-3xl space-y-4" id="plan-form">
        <PlanFormFields locale={locale} prefix="plan-edit" />
        <p class="text-sm text-[var(--color-text-soft)]" id="plan-form-message" role="status" aria-live="polite">{t('plan.form.helper')}</p>
        <div class="flex flex-wrap gap-3">
          <Button type="submit">{t('plan.form.save')}</Button>
        </div>
      </form>
    </div>
  </AppShell>
  <script>
    import { mountPlanEditPage } from '../../scripts/pages/plan-edit';

    mountPlanEditPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
