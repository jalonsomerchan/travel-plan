---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import Button from '../Button.astro';
import Container from '../Container.astro';
import PlanFormFields from '../app/PlanFormFields.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('planEdit.metaTitle')} description={t('planEdit.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('planEdit.eyebrow')}
    title={t('planEdit.title')}
    description={t('planEdit.description')}
    breadcrumbs={[{ label: t('nav.home'), href: getLocalizedPath('/', locale) }, { label: t('dashboard.breadcrumb'), href: dashboardUrl }, { label: t('trip.breadcrumb') }, { label: t('plan.breadcrumb') }, { label: t('planEdit.breadcrumb') }]}
  />
  <Container class="pb-12">
    <section class="section-shell mx-auto max-w-3xl px-6 py-6">
      <h2 class="text-2xl font-black" data-plan-context>{t('plan.detailsTitle')}</h2>
      <form class="mt-6 space-y-4" id="plan-form">
        <PlanFormFields locale={locale} prefix="plan-edit" />
        <p class="text-sm text-[var(--color-text-soft)]" id="plan-form-message">{t('plan.form.helper')}</p>
        <div class="flex flex-wrap gap-3">
          <Button type="submit">{t('plan.form.save')}</Button>
          <Button id="plan-edit-back-link" href={dashboardUrl} variant="secondary">{t('common.cancel')}</Button>
        </div>
      </form>
    </section>
  </Container>
  <script>
    import { mountPlanEditPage } from '../../scripts/pages/plan-edit';

    mountPlanEditPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
