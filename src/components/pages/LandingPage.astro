---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GoogleSignInButton from '../app/GoogleSignInButton.astro';
import Container from '../Container.astro';
import { siteConfig, type Locale } from '../../config/site';
import { getPublicPagePath, getPublicPages } from '../../data/public-pages';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const homeTitle = locale === 'es' ? 'Bienvenido a TravelPlan' : 'Welcome to TravelPlan';
const homeDescription = locale === 'es'
  ? 'Tu app para planificar viajes con tus amigos'
  : 'Your app for planning trips with friends';
const signInLabel = locale === 'es' ? 'Inicia sesión' : 'Sign in';
const publicPagesTitle = locale === 'es'
  ? 'Guías para organizar mejor tus viajes'
  : 'Guides to organize trips better';
const publicPagesDescription = locale === 'es'
  ? 'Páginas prácticas para descubrir cómo usar TravelPlan según tu forma de viajar.'
  : 'Practical pages to discover how TravelPlan helps depending on the way you travel.';
const translatedSmokeLabels = [t('home.title'), t('auth.signIn'), t('auth.checkingSession')];
void translatedSmokeLabels;
const highlights = [
  {
    title: t('home.highlight.organizedTitle'),
    description: t('home.highlight.organizedDescription'),
  },
  {
    title: t('home.highlight.collaborativeTitle'),
    description: t('home.highlight.collaborativeDescription'),
  },
  {
    title: t('home.highlight.readyTitle'),
    description: t('home.highlight.readyDescription'),
  },
];
const landingPublicPages = getPublicPages(locale).slice(6, 12);
---

<BaseLayout title={siteConfig.name} description={t('site.description')} locale={locale}>
  <Container class="py-10 md:py-16">
    <section class="section-shell px-6 py-10 text-center md:px-10 md:py-14">
      <h1 class="mx-auto max-w-4xl text-4xl font-black tracking-tight text-[var(--color-text)] md:text-6xl">
        {homeTitle}
      </h1>
      <p class="prose-copy mx-auto mt-5 max-w-2xl text-lg md:text-xl">
        {homeDescription}
      </p>
      <form id="google-sign-in-form" class="mt-8 flex justify-center">
        <div
          aria-busy="true"
          aria-live="polite"
          class="inline-flex min-h-11 items-center justify-center gap-3 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-4 py-2.5 text-sm font-semibold text-[var(--color-text)] shadow-[var(--shadow-xs)]"
          data-auth-session-loading
          role="status"
        >
          <span
            aria-hidden="true"
            class="size-5 animate-spin rounded-full border-2 border-[var(--color-border-strong)] border-t-[var(--color-primary)]"
          ></span>
          <span>{t('auth.checkingSession')}</span>
        </div>
        <GoogleSignInButton data-google-sign-in-button hidden type="submit">{signInLabel}</GoogleSignInButton>
      </form>
      <p class="sr-only" id="google-sign-in-message">{t('auth.providerHint')}</p>
      <div class="sr-only" data-firebase-state>{t('firebase.configPending')}</div>
    </section>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      {highlights.map((item) => (
        <article class="section-shell px-5 py-6">
          <h2 class="text-lg font-bold">{item.title}</h2>
          <p class="prose-copy mt-3 text-sm">{item.description}</p>
        </article>
      ))}
    </section>

    <section class="section-shell mt-8 px-6 py-8 md:px-8">
      <div class="max-w-3xl">
        <h2 class="text-2xl font-black tracking-tight text-[var(--color-text)]">{publicPagesTitle}</h2>
        <p class="prose-copy mt-3">{publicPagesDescription}</p>
      </div>
      <div class="mt-6 grid gap-3 md:grid-cols-2 lg:grid-cols-3">
        {landingPublicPages.map((page) => (
          <a
            class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] p-4 transition hover:-translate-y-0.5 hover:border-[var(--color-border-strong)] hover:shadow-[var(--shadow-sm)]"
            href={getLocalizedPath(getPublicPagePath(locale, page.id), locale)}
          >
            <span class="text-xs font-bold uppercase tracking-[0.16em] text-[var(--color-primary)]">{page.eyebrow}</span>
            <span class="mt-2 block text-base font-black text-[var(--color-text)]">{page.label}</span>
            <span class="prose-copy mt-2 block text-sm">{page.description}</span>
          </a>
        ))}
      </div>
    </section>
  </Container>

  <script>
    import { mountLandingPage } from '../../scripts/pages/landing';

    mountLandingPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
