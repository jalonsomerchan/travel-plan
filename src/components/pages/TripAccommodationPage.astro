---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import LoadingState from '../app/LoadingState.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import Button from '../Button.astro';
import AccommodationFormFields from '../app/AccommodationFormFields.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('accommodation.metaTitle')} description={t('accommodation.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('accommodation.eyebrow')}
    title={t('accommodation.title')}
    description={t('accommodation.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('accommodation.breadcrumb'), key: 'trip-accommodation' },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <div slot="body" class="pt-6">
      <div data-accommodation-view>
        <LoadingState label={t('common.loading')} />
      </div>
      <div class="mt-8 border-t border-[var(--color-border)] pt-8">
        <h2 class="text-2xl font-black" data-accommodation-context>{t('accommodation.detailsTitle')}</h2>
        <form class="mt-6 space-y-4 max-w-3xl" id="accommodation-form">
        <AccommodationFormFields locale={locale} prefix="trip-accommodation" />
        <p class="text-sm text-[var(--color-text-soft)]" id="accommodation-form-message">{t('accommodation.form.helper')}</p>
        <div class="flex flex-wrap gap-3">
          <Button type="submit">{t('accommodation.form.save')}</Button>
        </div>
        </form>
      </div>
    </div>
  </AppShell>

  <script>
    import { mountTripAccommodationPage } from '../../scripts/pages/trip-accommodation';

    mountTripAccommodationPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
