---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import PlanLocationFields from '../app/PlanLocationFields.astro';
import Button from '../Button.astro';
import Container from '../Container.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';
import { planCategoryValues, planStatusValues, tripMemberRoles, tripStatusValues } from '../../lib/app/models';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('trip.metaTitle')} description={t('trip.metaDescription')} locale={locale}>
  <AppShell eyebrow={t('trip.eyebrow')} title={t('trip.title')} description={t('trip.description')}>
    <div class="mt-8 flex flex-wrap gap-3">
      <Button href={dashboardUrl} variant="secondary">{t('trip.backToDashboard')}</Button>
      <Button id="trip-calendar-link" variant="secondary" href={dashboardUrl}>{t('trip.openCalendar')}</Button>
      <Button id="trip-map-link" variant="secondary" href={dashboardUrl}>{t('trip.openMap')}</Button>
    </div>
  </AppShell>

  <Container class="grid gap-8 pb-12 lg:grid-cols-[0.95fr_1.05fr]">
    <section class="section-shell px-6 py-6">
      <div>
        <span class="eyebrow">{t('trip.detailsEyebrow')}</span>
        <h2 class="mt-4 text-2xl font-black" data-trip-context>{t('trip.detailsTitle')}</h2>
      </div>
      <form class="mt-6 space-y-4" id="trip-form">
        <div>
          <label class="field-label" for="trip-edit-name">{t('trip.form.name')}</label>
          <input class="field-input" id="trip-edit-name" name="name" required />
        </div>
        <div>
          <label class="field-label" for="trip-edit-location">{t('trip.form.location')}</label>
          <input class="field-input" id="trip-edit-location" name="location" required />
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="field-label" for="trip-edit-start-date">{t('trip.form.startDate')}</label>
            <input class="field-input" id="trip-edit-start-date" name="startDate" type="date" required />
          </div>
          <div>
            <label class="field-label" for="trip-edit-end-date">{t('trip.form.endDate')}</label>
            <input class="field-input" id="trip-edit-end-date" name="endDate" type="date" required />
          </div>
        </div>
        <div>
          <label class="field-label" for="trip-edit-status">{t('trip.form.status')}</label>
          <select class="field-select" id="trip-edit-status" name="status">
            {tripStatusValues.map((status) => (
              <option value={status}>{t(`status.trip.${status}`)}</option>
            ))}
          </select>
        </div>
        <p class="text-sm text-[var(--color-text-soft)]" id="trip-form-message">{t('trip.form.helper')}</p>
        <Button class="w-full" type="submit">{t('trip.form.save')}</Button>
      </form>
    </section>

    <section class="space-y-8">
      <article class="section-shell px-6 py-6">
        <div>
          <span class="eyebrow">{t('trip.membersEyebrow')}</span>
          <h2 class="mt-4 text-2xl font-black">{t('trip.membersTitle')}</h2>
        </div>
        <form class="mt-6 grid gap-4 md:grid-cols-[1fr_auto_auto]" id="invite-form">
          <div>
            <label class="field-label" for="invite-email">{t('trip.invite.email')}</label>
            <input class="field-input" id="invite-email" name="email" type="email" required />
          </div>
          <div>
            <label class="field-label" for="invite-role">{t('trip.invite.role')}</label>
            <select class="field-select" id="invite-role" name="role">
              {tripMemberRoles.map((role) => (
                <option value={role}>{t(`role.${role}`)}</option>
              ))}
            </select>
          </div>
          <div class="flex items-end">
            <Button class="w-full md:w-auto" type="submit">{t('trip.invite.action')}</Button>
          </div>
        </form>
        <p class="mt-4 text-sm text-[var(--color-text-soft)]" id="invite-message">{t('trip.invite.helper')}</p>
        <div class="mt-6 grid gap-4" data-member-list>
          <article class="rounded-[var(--radius-lg)] border border-dashed border-[var(--color-border)] bg-[var(--color-surface-soft)] px-5 py-8 text-center text-sm text-[var(--color-text-soft)]">
            {t('common.loading')}
          </article>
        </div>
      </article>

      <article class="section-shell px-6 py-6">
        <div>
          <span class="eyebrow">{t('trip.plansEyebrow')}</span>
          <h2 class="mt-4 text-2xl font-black">{t('trip.plansTitle')}</h2>
        </div>
        <form class="mt-6 space-y-4" id="plan-create-form">
          <div>
            <label class="field-label" for="plan-create-name">{t('plan.form.name')}</label>
            <input class="field-input" id="plan-create-name" name="name" required />
          </div>
          <div>
            <label class="field-label" for="plan-create-description">{t('plan.form.description')}</label>
            <textarea class="field-textarea" id="plan-create-description" name="description"></textarea>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="field-label" for="plan-create-category">{t('plan.form.category')}</label>
              <select class="field-select" id="plan-create-category" name="category">
                {planCategoryValues.map((category) => (
                  <option value={category}>{t(`category.${category}`)}</option>
                ))}
              </select>
            </div>
            <div>
              <label class="field-label" for="plan-create-status">{t('plan.form.status')}</label>
              <select class="field-select" id="plan-create-status" name="status">
                {planStatusValues.map((status) => (
                  <option value={status}>{t(`status.plan.${status}`)}</option>
                ))}
              </select>
            </div>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            <div>
              <label class="field-label" for="plan-create-date">{t('plan.form.date')}</label>
              <input class="field-input" id="plan-create-date" name="date" type="date" />
            </div>
            <div>
              <label class="field-label" for="plan-create-time">{t('plan.form.time')}</label>
              <input class="field-input" id="plan-create-time" name="time" type="time" />
            </div>
          </div>
          <PlanLocationFields locale={locale} prefix="plan-create" />
          <p class="text-sm text-[var(--color-text-soft)]" id="plan-create-message">{t('trip.plansHelper')}</p>
          <Button class="w-full" type="submit">{t('trip.plansAction')}</Button>
        </form>
        <div class="mt-6 grid gap-4" data-plan-list>
          <article class="rounded-[var(--radius-lg)] border border-dashed border-[var(--color-border)] bg-[var(--color-surface-soft)] px-5 py-8 text-center text-sm text-[var(--color-text-soft)]">
            {t('common.loading')}
          </article>
        </div>
      </article>
    </section>
  </Container>

  <script>
    import { mountTripPage } from '../../scripts/pages/trip';

    mountTripPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
