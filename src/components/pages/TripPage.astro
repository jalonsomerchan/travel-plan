---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import LoadingState from '../app/LoadingState.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import TripSectionNav from '../app/TripSectionNav.astro';
import Button from '../Button.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
const plansTitle = locale === 'es' ? 'Planes y lugares' : 'Plans and places';
---

<BaseLayout title={t('trip.metaTitle')} description={t('trip.metaDescription')} locale={locale}>
  <AppShell
    title={t('trip.title')}
    description={t('trip.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <TripSectionNav slot="nav" locale={locale} fallbackHref={dashboardUrl} />

    <div slot="body" class="pt-6">
      <div class="mb-6" data-trip-weather-card>
        <LoadingState label={t('common.loading')} />
      </div>
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <h2 class="text-2xl font-black">{plansTitle}</h2>
        <div class="flex flex-wrap items-center gap-3">
          <button
            aria-label={t('plan.location.getDirections')}
            class="app-card-link min-w-11 px-0 text-xl leading-none"
            data-current-location-action
            data-variant="secondary"
            hidden
            title={t('plan.location.getDirections')}
            type="button"
          >
            <span aria-hidden="true">📍</span>
          </button>
          <Button
            aria-label={t('trip.goAiSuggestions')}
            href={dashboardUrl}
            id="trip-ai-inline-link"
            title={t('trip.goAiSuggestions')}
            variant="secondary"
          >
            {t('trip.goAiSuggestions')}
          </Button>
          <Button
            aria-label={t('trip.goCreatePlan')}
            class="min-w-11 px-0 text-2xl leading-none"
            href={dashboardUrl}
            id="trip-create-plan-inline-link"
            title={t('trip.goCreatePlan')}
          >
            +
          </Button>
        </div>
      </div>
      <a
        class="mt-5 flex min-w-0 items-start gap-3 rounded-[var(--radius-lg)] border border-[var(--color-warning)] bg-[var(--color-warning-soft)] px-4 py-4 text-sm font-semibold leading-snug text-[var(--color-text)] transition hover:opacity-90"
        data-trip-checklist-notice
        href={dashboardUrl}
        hidden
        id="trip-checklist-notice-link"
      ></a>
      <div class="mt-5">
        <button
          aria-controls="trip-plan-filters"
          aria-expanded="false"
          class="inline-flex min-h-11 w-full items-center justify-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-4 py-2.5 text-sm font-bold text-[var(--color-text)] shadow-[var(--shadow-xs)] sm:hidden"
          data-plan-filters-toggle
          type="button"
        >
          <span aria-hidden="true">▾</span>
          <span>{t('trip.filters.toggle')}</span>
        </button>
        <form class="mt-3 hidden gap-3 sm:grid sm:grid-cols-3" data-plan-filters id="trip-plan-filters">
          <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
            <span>{t('trip.filters.search')}</span>
            <input
              class="min-h-11 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-[var(--color-text)]"
              data-plan-filter-search
              name="search"
              type="search"
            />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
            <span>{t('trip.filters.category')}</span>
            <select
              class="min-h-11 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-[var(--color-text)]"
              data-plan-filter-category
              name="category"
            >
              <option value="all">{t('trip.filters.allCategories')}</option>
            </select>
          </label>
          <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
            <span>{t('trip.filters.status')}</span>
            <select
              class="min-h-11 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-[var(--color-text)]"
              data-plan-filter-status
              name="status"
            >
              <option value="all">{t('trip.filters.allStatuses')}</option>
            </select>
          </label>
        </form>
      </div>
      <div class="mt-6 grid gap-4" data-plan-list>
        <LoadingState label={t('common.loading')} />
      </div>
    </div>
  </AppShell>

  <style is:global>
    [data-trip-weather-card] .app-card-shell {
      display: block;
      overflow: hidden;
      padding: 0;
    }

    .trip-weather-card-inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1rem;
      align-items: center;
      padding: 1.2rem;
      background:
        radial-gradient(circle at top right, color-mix(in srgb, var(--color-secondary-soft), transparent 10%), transparent 45%),
        linear-gradient(180deg, color-mix(in srgb, var(--color-surface-raised), transparent 4%), var(--color-surface-raised));
    }

    .trip-weather-card-copy {
      min-width: 0;
    }

    .trip-weather-card-title {
      margin: 0.35rem 0 0;
      font-size: 1.35rem;
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 1.05;
    }

    .trip-weather-card-location {
      margin: 0;
      color: var(--color-text-soft);
      font-size: 0.92rem;
      font-weight: 700;
    }

    .trip-weather-card-helper {
      margin: 0.45rem 0 0;
      color: var(--color-text-soft);
      font-size: 0.96rem;
      max-width: 44rem;
    }

    .trip-weather-card-days {
      display: grid;
      gap: 0.8rem;
      margin-top: 1rem;
    }

    .trip-weather-day-card {
      border-radius: var(--radius-lg);
      border: 1px solid var(--color-border);
      background: color-mix(in srgb, var(--color-surface-soft), transparent 20%);
      padding: 0.95rem;
    }

    .trip-weather-day-label {
      margin: 0;
      color: var(--color-text-soft);
      font-size: 0.85rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .trip-weather-day-summary {
      margin: 0.35rem 0 0;
      color: var(--color-text-muted);
      font-size: 0.96rem;
      font-weight: 700;
    }

    .trip-weather-day-main {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.85rem;
      margin-top: 0.85rem;
    }

    .trip-weather-day-temperatures {
      display: grid;
      gap: 0.15rem;
      text-align: right;
    }

    .trip-weather-day-temperatures strong {
      font-size: 1.2rem;
      line-height: 1;
    }

    .trip-weather-day-temperatures span {
      color: var(--color-text-soft);
      font-size: 0.9rem;
      font-weight: 700;
    }

    .trip-weather-card-arrow {
      color: var(--color-text-soft);
      font-size: 2rem;
      line-height: 1;
    }

    .weather-icon-svg {
      width: 3rem;
      height: 3rem;
      flex-shrink: 0;
    }

    @media (min-width: 48rem) {
      .trip-weather-card-inner {
        padding: 1.35rem 1.45rem;
      }

      .trip-weather-card-days {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    [data-plan-list] .app-card-shell {
      cursor: pointer;
    }

    [data-plan-list] .app-actions-menu,
    [data-plan-list] .app-actions-menu * {
      cursor: auto;
    }
  </style>

  <script>
    import { mountTripPage } from '../../scripts/pages/trip';

    mountTripPage({ locale: document.documentElement.lang });

    const planList = document.querySelector<HTMLElement>('[data-plan-list]');

    planList?.addEventListener('click', (event) => {
      if (event.defaultPrevented || !(event.target instanceof HTMLElement)) {
        return;
      }

      if (event.target.closest('a, button, details, summary, input, select, textarea, label')) {
        return;
      }

      const card = event.target.closest<HTMLElement>('.app-card-shell');
      const link = card?.querySelector<HTMLAnchorElement>('a[href]');

      if (link) {
        window.location.href = link.href;
      }
    });
  </script>
</BaseLayout>
