---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import AppToolbar from '../app/AppToolbar.astro';
import Button from '../Button.astro';
import Container from '../Container.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('trip.metaTitle')} description={t('trip.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('trip.eyebrow')}
    title={t('trip.title')}
    description={t('trip.description')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
    ]}
  >
    <AppToolbar>
      <div slot="secondary">
        <Button href={dashboardUrl} variant="ghost">{t('trip.backToDashboard')}</Button>
        <Button id="trip-edit-link" variant="ghost" href={dashboardUrl}>{t('trip.goEdit')}</Button>
        <Button id="trip-members-link" variant="ghost" href={dashboardUrl}>{t('trip.goMembers')}</Button>
        <Button id="trip-calendar-link" variant="ghost" href={dashboardUrl}>{t('trip.openCalendar')}</Button>
        <Button id="trip-map-link" variant="ghost" href={dashboardUrl}>{t('trip.openMap')}</Button>
      </div>
      <div slot="primary">
        <Button id="trip-create-plan-link" href={dashboardUrl}>{t('trip.goCreatePlan')}</Button>
      </div>
    </AppToolbar>
  </AppShell>

  <Container class="grid gap-8 pb-12">
    <section class="section-shell px-6 py-6">
      <div>
        <span class="eyebrow">{t('trip.plansEyebrow')}</span>
        <h2 class="mt-4 text-2xl font-black">{t('trip.plansTitle')}</h2>
      </div>
      <div class="mt-6 grid gap-4" data-plan-list>
        <article class="rounded-[var(--radius-lg)] border border-dashed border-[var(--color-border)] bg-[var(--color-surface-soft)] px-5 py-8 text-center text-sm text-[var(--color-text-soft)]">
          {t('common.loading')}
        </article>
      </div>
    </section>
  </Container>

  <script>
    import { mountTripPage } from '../../scripts/pages/trip';

    mountTripPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
