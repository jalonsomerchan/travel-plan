---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import LoadingState from '../app/LoadingState.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import Button from '../Button.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
const plansTitle = locale === 'es' ? 'Planes y lugares' : 'Plans and places';
---

<BaseLayout title={t('trip.metaTitle')} description={t('trip.metaDescription')} locale={locale}>
  <AppShell
    title={t('trip.title')}
    description={t('trip.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />

    <div slot="body" class="mt-8 border-t border-[var(--color-border)] pt-6">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <h2 class="text-2xl font-black">{plansTitle}</h2>
        <div class="flex flex-wrap items-center gap-3">
          <button
            aria-label={t('plan.location.getDirections')}
            class="app-card-link min-w-11 px-0 text-xl leading-none"
            data-current-location-action
            data-variant="secondary"
            hidden
            title={t('plan.location.getDirections')}
            type="button"
          >
            <span aria-hidden="true">📍</span>
          </button>
          <Button
            aria-label={t('trip.goAiSuggestions')}
            href={dashboardUrl}
            id="trip-ai-inline-link"
            title={t('trip.goAiSuggestions')}
            variant="secondary"
          >
            {t('trip.goAiSuggestions')}
          </Button>
          <Button
            aria-label={t('trip.goCreatePlan')}
            class="min-w-11 px-0 text-2xl leading-none"
            href={dashboardUrl}
            id="trip-create-plan-inline-link"
            title={t('trip.goCreatePlan')}
          >
            +
          </Button>
        </div>
      </div>
      <a
        class="mt-5 rounded-[var(--radius-lg)] border border-[var(--color-warning)] bg-[var(--color-warning-soft)] px-4 py-4 text-sm font-semibold text-[var(--color-text)] transition hover:opacity-90"
        data-trip-checklist-notice
        href={dashboardUrl}
        hidden
        id="trip-checklist-notice-link"
      ></a>
      <div class="mt-5">
        <form class="grid gap-3 sm:grid-cols-3" data-plan-filters>
          <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
            <span>{t('trip.filters.search')}</span>
            <input
              class="min-h-11 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-[var(--color-text)]"
              data-plan-filter-search
              name="search"
              type="search"
            />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
            <span>{t('trip.filters.category')}</span>
            <select
              class="min-h-11 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-[var(--color-text)]"
              data-plan-filter-category
              name="category"
            >
              <option value="all">{t('trip.filters.allCategories')}</option>
            </select>
          </label>
          <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
            <span>{t('trip.filters.status')}</span>
            <select
              class="min-h-11 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-[var(--color-text)]"
              data-plan-filter-status
              name="status"
            >
              <option value="all">{t('trip.filters.allStatuses')}</option>
            </select>
          </label>
        </form>
      </div>
      <div class="mt-6 grid gap-4" data-plan-list>
        <LoadingState label={t('common.loading')} />
      </div>
    </div>
  </AppShell>

  <script>
    import { mountTripPage } from '../../scripts/pages/trip';

    mountTripPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
