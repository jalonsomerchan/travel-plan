---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppActionsMenu from '../app/AppActionsMenu.astro';
import AppBackButton from '../app/AppBackButton.astro';
import AppShell from '../app/AppShell.astro';
import Button from '../Button.astro';
import Container from '../Container.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('trip.metaTitle')} description={t('trip.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('trip.eyebrow')}
    title={t('trip.title')}
    description={t('trip.description')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
    ]}
  >
    <div slot="topbar" class="app-shell-topbar-row">
      <AppBackButton fallbackHref={dashboardUrl} label={t('common.goBack')} />
      <AppActionsMenu
        ariaLabel={t('trip.actionsMenu')}
        label="..."
        items={[
          { href: dashboardUrl, id: 'trip-create-plan-link', label: t('trip.goCreatePlan') },
          { href: dashboardUrl, id: 'trip-members-link', label: t('trip.goMembers') },
          { href: dashboardUrl, id: 'trip-calendar-link', label: t('trip.openCalendar') },
          { href: dashboardUrl, id: 'trip-map-link', label: t('trip.openMap') },
          { href: dashboardUrl, id: 'trip-edit-link', label: t('trip.goEdit') },
        ]}
      />
    </div>
  </AppShell>

  <Container class="grid gap-8 pb-12">
    <section class="section-shell px-6 py-6">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <span class="eyebrow">{t('trip.plansEyebrow')}</span>
          <h2 class="mt-4 text-2xl font-black">{t('trip.plansTitle')}</h2>
        </div>
        <Button
          aria-label={t('trip.goCreatePlan')}
          class="min-w-11 px-0 text-2xl leading-none"
          href={dashboardUrl}
          id="trip-create-plan-inline-link"
          title={t('trip.goCreatePlan')}
        >
          +
        </Button>
      </div>
      <div class="mt-5">
        <form class="grid gap-3 sm:grid-cols-3" data-plan-filters>
          <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
            <span>{t('trip.filters.search')}</span>
            <input
              class="min-h-11 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-[var(--color-text)]"
              data-plan-filter-search
              name="search"
              type="search"
            />
          </label>
          <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
            <span>{t('trip.filters.category')}</span>
            <select
              class="min-h-11 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-[var(--color-text)]"
              data-plan-filter-category
              name="category"
            >
              <option value="all">{t('trip.filters.allCategories')}</option>
            </select>
          </label>
          <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
            <span>{t('trip.filters.status')}</span>
            <select
              class="min-h-11 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-[var(--color-text)]"
              data-plan-filter-status
              name="status"
            >
              <option value="all">{t('trip.filters.allStatuses')}</option>
            </select>
          </label>
        </form>
      </div>
      <div class="mt-6 grid gap-4" data-plan-list>
        <article class="rounded-[var(--radius-lg)] border border-dashed border-[var(--color-border)] bg-[var(--color-surface-soft)] px-5 py-8 text-center text-sm text-[var(--color-text-soft)]">
          {t('common.loading')}
        </article>
      </div>
    </section>
  </Container>

  <script>
    import { mountTripPage } from '../../scripts/pages/trip';

    mountTripPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
