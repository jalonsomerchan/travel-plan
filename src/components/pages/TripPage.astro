---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import LoadingState from '../app/LoadingState.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import TripSectionNav from '../app/TripSectionNav.astro';
import Button from '../Button.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('trip.metaTitle')} description={t('trip.metaDescription')} locale={locale}>
  <AppShell
    tripContext
    title={t('trip.title')}
    description={t('trip.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu slot="trip-context-action" locale={locale} fallbackHref={dashboardUrl} />
    <TripSectionNav slot="nav" locale={locale} fallbackHref={dashboardUrl} />

    <div slot="body" class="pt-6">
      <section
        class="mb-6 rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-4 py-4 shadow-[var(--shadow-xs)]"
        data-parent-trip-banner
        hidden
      >
        <p class="text-xs font-black uppercase tracking-[0.14em] text-[var(--color-text-soft)]">{t('trip.miniTrips.parentEyebrow')}</p>
        <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
          <p class="text-sm text-[var(--color-text-muted)]">
            {t('trip.miniTrips.parentDescription')}
            <a class="font-bold text-[var(--color-primary)]" data-parent-trip-link href="#">
              <span data-parent-trip-name></span>
            </a>
          </p>
          <a class="app-card-link" data-parent-trip-action hidden href="#">{t('trip.miniTrips.backToParent')}</a>
        </div>
      </section>
      <div class="mb-6" data-trip-weather-card>
        <LoadingState label={t('common.loading')} />
      </div>
      <div class="trip-view-tabs" data-trip-tabs hidden role="tablist" aria-label={t('trip.tabs.label')}>
        <button
          aria-controls="trip-plans-panel"
          aria-selected="true"
          class="trip-view-tab"
          data-trip-tab="plans"
          id="trip-plans-tab"
          role="tab"
          type="button"
        >
          {t('trip.tabs.plans')}
        </button>
        <button
          aria-controls="trip-mini-trips-panel"
          aria-selected="false"
          class="trip-view-tab"
          data-trip-tab="mini-trips"
          id="trip-mini-trips-tab"
          role="tab"
          tabindex="-1"
          type="button"
        >
          {t('trip.tabs.miniTrips')}
        </button>
      </div>
      <section data-trip-panel="plans" id="trip-plans-panel" role="tabpanel" aria-labelledby="trip-plans-tab">
        <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
          <h2 class="text-2xl font-black">{t('trip.plansTitle')}</h2>
          <div class="flex flex-wrap items-center gap-3">
            <button
              aria-label={t('plan.location.getDirections')}
              class="app-card-link min-w-11 px-0 text-xl leading-none"
              data-current-location-action
              data-variant="secondary"
              hidden
              title={t('plan.location.getDirections')}
              type="button"
            >
              <span aria-hidden="true">📍</span>
            </button>
            <Button
              aria-label={t('trip.goAiSuggestions')}
              href={dashboardUrl}
              id="trip-ai-inline-link"
              title={t('trip.goAiSuggestions')}
              variant="secondary"
            >
              {t('trip.goAiSuggestions')}
            </Button>
            <Button
              aria-label={t('trip.goCreatePlan')}
              class="min-w-11 px-0 text-2xl leading-none"
              href={dashboardUrl}
              id="trip-create-plan-inline-link"
              title={t('trip.goCreatePlan')}
            >
              +
            </Button>
          </div>
        </div>
        <a
          class="mt-5 flex min-w-0 items-start gap-3 rounded-[var(--radius-lg)] border border-[var(--color-warning)] bg-[var(--color-warning-soft)] px-4 py-4 text-sm font-semibold leading-snug text-[var(--color-text)] transition hover:opacity-90"
          data-trip-checklist-notice
          href={dashboardUrl}
          hidden
          id="trip-checklist-notice-link"
        ></a>
        <div class="mt-5">
          <button
            aria-controls="trip-plan-filters"
            aria-expanded="false"
            class="inline-flex min-h-11 w-full items-center justify-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-4 py-2.5 text-sm font-bold text-[var(--color-text)] shadow-[var(--shadow-xs)] sm:hidden"
            data-plan-filters-toggle
            type="button"
          >
            <span aria-hidden="true">▾</span>
            <span>{t('trip.filters.toggle')}</span>
          </button>
          <form
            class="mt-3 hidden grid-cols-2 gap-3 sm:grid sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5"
            data-plan-filters
            id="trip-plan-filters"
          >
            <label class="col-span-full grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
              <span>{t('trip.filters.search')}</span>
              <input
                class="min-h-10 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-sm text-[var(--color-text)]"
                data-plan-filter-search
                name="search"
                type="search"
              />
            </label>
            <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
              <span>{t('trip.filters.category')}</span>
              <select
                class="min-h-10 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-sm text-[var(--color-text)]"
                data-plan-filter-category
                name="category"
              >
                <option value="all">{t('trip.filters.allCategories')}</option>
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
              <span>{t('trip.filters.status')}</span>
              <select
                class="min-h-10 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-sm text-[var(--color-text)]"
                data-plan-filter-status
                name="status"
              >
                <option value="all">{t('trip.filters.allStatuses')}</option>
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
              <span>{t('trip.filters.price')}</span>
              <select
                class="min-h-10 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-sm text-[var(--color-text)]"
                data-plan-filter-paid
                name="paid"
              >
                <option value="all">{t('trip.filters.allPrices')}</option>
                <option value="yes">{t('trip.filters.paidOnly')}</option>
                <option value="no">{t('trip.filters.freeOnly')}</option>
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
              <span>{t('trip.filters.booking')}</span>
              <select
                class="min-h-10 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-sm text-[var(--color-text)]"
                data-plan-filter-booked
                name="booked"
              >
                <option value="all">{t('trip.filters.allBookingOptions')}</option>
                <option value="yes">{t('trip.filters.bookedOnly')}</option>
                <option value="no">{t('trip.filters.notBookedOnly')}</option>
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
              <span>{t('trip.filters.dateMode')}</span>
              <select
                class="min-h-10 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-sm text-[var(--color-text)]"
                data-plan-filter-date
                name="date"
              >
                <option value="all">{t('trip.filters.allDates')}</option>
                <option value="today">{t('trip.filters.todayOnly')}</option>
                <option value="no-date">{t('trip.filters.noDateOnly')}</option>
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
              <span>{t('trip.filters.importance')}</span>
              <select
                class="min-h-10 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-sm text-[var(--color-text)]"
                data-plan-filter-important
                name="important"
              >
                <option value="all">{t('trip.filters.allImportance')}</option>
                <option value="yes">{t('trip.filters.importantOnly')}</option>
                <option value="no">{t('trip.filters.notImportantOnly')}</option>
              </select>
            </label>
            <label class="grid gap-2 text-sm font-semibold text-[var(--color-text-muted)]">
              <span>{t('trip.filters.guide')}</span>
              <select
                class="min-h-10 rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] px-3 text-sm text-[var(--color-text)]"
                data-plan-filter-guide
                name="guide"
              >
                <option value="all">{t('trip.filters.allGuides')}</option>
                <option value="yes">{t('trip.filters.withGuide')}</option>
                <option value="no">{t('trip.filters.withoutGuide')}</option>
              </select>
            </label>
          </form>
        </div>
        <div class="mt-6 grid gap-4" data-plan-list>
          <LoadingState label={t('common.loading')} />
        </div>
      </section>
      <section
        class="mt-8 border-t border-[var(--color-border)] pt-8"
        data-mini-trips-section
        data-trip-panel="mini-trips"
        hidden
        id="trip-mini-trips-panel"
        role="tabpanel"
        aria-labelledby="trip-mini-trips-tab"
      >
        <div>
          <p class="text-xs font-black uppercase tracking-[0.14em] text-[var(--color-text-soft)]">{t('trip.miniTrips.eyebrow')}</p>
          <h2 class="mt-2 text-2xl font-black text-[var(--color-text)]">{t('trip.miniTrips.title')}</h2>
          <p class="mt-2 text-sm text-[var(--color-text-soft)]" data-mini-trip-count>{t('trip.miniTrips.count').replace('{count}', '0')}</p>
        </div>
        <div class="mt-6 grid gap-4" data-mini-trip-list>
          <LoadingState label={t('common.loading')} />
        </div>
      </section>
    </div>
  </AppShell>

  <style is:global>
    .trip-view-tabs {
      display: flex;
      gap: 0.65rem;
      max-width: 100%;
      overflow-x: auto;
      padding-bottom: 0.15rem;
      margin-bottom: 1.5rem;
      scrollbar-width: thin;
    }

    .trip-view-tab {
      flex: 0 0 auto;
      min-height: 2.6rem;
      border-radius: 999px;
      border: 1px solid var(--color-border);
      background: var(--color-surface-soft);
      padding: 0.6rem 0.95rem;
      font-size: 0.9rem;
      font-weight: 800;
      color: var(--color-text-muted);
      transition:
        background var(--transition-base, 180ms ease),
        color var(--transition-base, 180ms ease),
        border-color var(--transition-base, 180ms ease);
    }

    .trip-view-tab[aria-selected="true"] {
      border-color: color-mix(in srgb, var(--color-primary), transparent 40%);
      background: color-mix(in srgb, var(--color-primary-soft), var(--color-surface-raised) 35%);
      color: var(--color-text);
    }

    [data-trip-weather-card] .app-card-shell {
      display: block;
      overflow: hidden;
      padding: 0;
    }

    .trip-weather-card-inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 1rem;
      align-items: center;
      padding: 0.9rem 1rem;
      background:
        radial-gradient(circle at top right, color-mix(in srgb, var(--color-secondary-soft), transparent 10%), transparent 45%),
        linear-gradient(180deg, color-mix(in srgb, var(--color-surface-raised), transparent 4%), var(--color-surface-raised));
    }

    .trip-weather-card-copy {
      min-width: 0;
    }

    .trip-weather-card-title {
      margin: 0.15rem 0 0;
      font-size: 1.05rem;
      font-weight: 900;
      letter-spacing: -0.03em;
      line-height: 1.1;
    }

    .trip-weather-card-helper {
      margin: 0.2rem 0 0;
      color: var(--color-text-soft);
      font-size: 0.86rem;
      max-width: 44rem;
    }

    .trip-weather-card-days {
      display: grid;
      gap: 0.35rem;
      margin-top: 0.55rem;
    }

    .trip-weather-day-row {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.65rem;
      align-items: center;
      min-width: 0;
    }

    .trip-weather-day-label {
      margin: 0;
      color: var(--color-text-soft);
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .trip-weather-day-summary {
      margin: 0;
      color: var(--color-text-muted);
      font-size: 0.96rem;
      font-weight: 800;
      line-height: 1.1;
    }

    .trip-weather-day-icon {
      display: flex;
      align-items: center;
      justify-content: flex-start;
      flex-shrink: 0;
    }

    .trip-weather-day-copy {
      min-width: 0;
    }

    .trip-weather-day-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      justify-content: space-between;
      gap: 0.45rem 0.8rem;
      margin-top: 0.2rem;
    }

    .trip-weather-day-temperatures {
      display: grid;
      gap: 0.15rem;
      text-align: right;
    }

    .trip-weather-day-temperatures--inline {
      display: inline-flex;
      align-items: baseline;
      gap: 0.35rem;
      white-space: nowrap;
    }

    .trip-weather-day-temperatures strong,
    .trip-weather-day-temperatures em {
      font-size: 0.96rem;
      font-style: normal;
      font-weight: 800;
      line-height: 1.1;
    }

    .trip-weather-day-temperatures strong {
      line-height: 1;
      color: var(--color-danger);
    }

    .trip-weather-day-temperatures span {
      color: var(--color-text-soft);
      font-size: 0.8rem;
      font-weight: 700;
    }

    .trip-weather-day-temperatures em {
      color: var(--color-info);
    }

    .trip-weather-card-arrow {
      color: var(--color-text-soft);
      font-size: 1.55rem;
      line-height: 1;
    }

    .weather-icon-svg {
      width: 3.35rem;
      height: 3.35rem;
      flex-shrink: 0;
    }

    @media (min-width: 48rem) {
      .trip-weather-card-inner {
        padding: 0.95rem 1.1rem;
      }

      .trip-weather-card-days {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    [data-plan-list] .app-card-shell {
      cursor: pointer;
    }

    [data-plan-list] .app-actions-menu,
    [data-plan-list] .app-actions-menu * {
      cursor: auto;
    }
  </style>

  <script>
    import { mountTripPage } from '../../scripts/pages/trip';

    mountTripPage({ locale: document.documentElement.lang });

    const planList = document.querySelector<HTMLElement>('[data-plan-list]');

    planList?.addEventListener('click', (event) => {
      if (event.defaultPrevented || !(event.target instanceof HTMLElement)) {
        return;
      }

      if (event.target.closest('a, button, details, summary, input, select, textarea, label')) {
        return;
      }

      const card = event.target.closest<HTMLElement>('.app-card-shell');
      const link = card?.querySelector<HTMLAnchorElement>('a[href]');

      if (link) {
        window.location.href = link.href;
      }
    });
  </script>
</BaseLayout>
