---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppBackButton from '../app/AppBackButton.astro';
import AppShell from '../app/AppShell.astro';
import DashboardSectionNav from '../app/DashboardSectionNav.astro';
import LoadingState from '../app/LoadingState.astro';
import Button from '../Button.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('today.metaTitle')} description={t('today.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('today.eyebrow')}
    title={t('today.title')}
    description={t('today.description')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('today.breadcrumb') },
    ]}
    compactTop
  >
    <AppBackButton slot="topbar" fallbackHref={dashboardUrl} label={t('common.goBack')} />
    <DashboardSectionNav slot="nav" locale={locale} />
    <div slot="body" class="mt-8 border-t border-[var(--color-border)] pt-6">
      <form
        class="grid gap-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-4"
        data-today-filters
      >
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <span class="eyebrow">{t('today.filters.eyebrow')}</span>
            <h2 class="mt-2 text-2xl font-black">{t('today.filters.title')}</h2>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <Button type="button" variant="secondary" data-today-location-action>
              {t('today.location.use')}
            </Button>
            <Button type="button" variant="ghost" data-today-map-toggle aria-controls="today-map-panel">
              {t('today.map.toggle')}
            </Button>
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          <label class="grid gap-2 text-sm font-bold text-[var(--color-text)]">
            <span>{t('trip.filters.search')}</span>
            <input
              class="input"
              type="search"
              name="search"
              autocomplete="off"
              placeholder={t('today.filters.searchPlaceholder')}
              data-today-filter-search
            />
          </label>
          <label class="grid gap-2 text-sm font-bold text-[var(--color-text)]">
            <span>{t('today.filters.trip')}</span>
            <select class="select" name="trip" data-today-filter-trip>
              <option value="all">{t('today.filters.allTrips')}</option>
            </select>
          </label>
          <label class="grid gap-2 text-sm font-bold text-[var(--color-text)]">
            <span>{t('trip.filters.category')}</span>
            <select class="select" name="category" data-today-filter-category>
              <option value="all">{t('trip.filters.allCategories')}</option>
            </select>
          </label>
          <label class="grid gap-2 text-sm font-bold text-[var(--color-text)]">
            <span>{t('today.filters.status')}</span>
            <select class="select" name="status" data-today-filter-status>
              <option value="pending">{t('today.filters.statusPending')}</option>
              <option value="proposed">{t('today.filters.statusProposed')}</option>
              <option value="all-open">{t('today.filters.statusAllOpen')}</option>
            </select>
          </label>
          <label class="grid gap-2 text-sm font-bold text-[var(--color-text)]">
            <span>{t('today.filters.maxDistance')}</span>
            <select class="select" name="distance" data-today-filter-distance>
              <option value="all">{t('today.filters.allDistances')}</option>
              <option value="1">{t('today.filters.distanceOption').replace('{distance}', '1 km')}</option>
              <option value="5">{t('today.filters.distanceOption').replace('{distance}', '5 km')}</option>
              <option value="10">{t('today.filters.distanceOption').replace('{distance}', '10 km')}</option>
              <option value="25">{t('today.filters.distanceOption').replace('{distance}', '25 km')}</option>
              <option value="50">{t('today.filters.distanceOption').replace('{distance}', '50 km')}</option>
            </select>
          </label>
          <label class="grid gap-2 text-sm font-bold text-[var(--color-text)]">
            <span>{t('today.filters.date')}</span>
            <input class="input" type="date" name="date" data-today-filter-date />
          </label>
        </div>

        <label class="inline-flex items-start gap-3 text-sm font-semibold text-[var(--color-text)]">
          <input
            class="mt-1 h-4 w-4 rounded border-[var(--color-border-strong)] text-[var(--color-primary)]"
            type="checkbox"
            name="includeWithoutDate"
            data-today-filter-without-date
          />
          <span>{t('today.filters.includeWithoutDate')}</span>
        </label>

        <div class="grid gap-3">
          <p
            class="min-w-0 text-sm font-semibold text-[var(--color-text-muted)]"
            data-today-location-status
            role="status"
            aria-live="polite"
            hidden
          >
          </p>
          <p
            class="min-w-0 text-xs font-semibold text-[var(--color-text-soft)]"
            data-today-distance-hint
            role="status"
            aria-live="polite"
          >
            {t('today.filters.distanceHint')}
          </p>
        </div>
      </form>

      <div class="mt-5 grid gap-4">
        <div data-today-summary role="status" aria-live="polite"></div>

        <details
          class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-raised)]"
          data-today-map-panel
          id="today-map-panel"
        >
          <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 text-sm font-black text-[var(--color-text)]">
            <span>{t('today.map.toggle')}</span>
            <span class="text-xs font-semibold text-[var(--color-text-soft)]" data-today-map-toggle-state>
              {t('today.map.collapsed')}
            </span>
          </summary>
          <div class="border-t border-[var(--color-border)] p-4">
            <p class="text-sm text-[var(--color-text-soft)]" data-today-map-status role="status" aria-live="polite">
              {t('today.map.idle')}
            </p>
            <div
              class="mt-4 hidden h-[20rem] overflow-hidden rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] sm:h-[24rem]"
              data-today-map-canvas
              aria-label={t('today.map.canvasLabel')}
            ></div>
          </div>
        </details>
      </div>

      <div class="mt-6 grid gap-8" data-today-list>
        <LoadingState label={t('common.loading')} />
      </div>
    </div>
  </AppShell>

  <script>
    import { mountGlobalTodayPage } from '../../scripts/pages/global-today';

    mountGlobalTodayPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
