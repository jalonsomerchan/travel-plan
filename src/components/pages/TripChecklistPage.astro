---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import ChecklistItemFormFields from '../app/ChecklistItemFormFields.astro';
import LoadingState from '../app/LoadingState.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import Button from '../Button.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('tripChecklist.metaTitle')} description={t('tripChecklist.metaDescription')} locale={locale}>
  <AppShell
    tripContext
    title={t('tripChecklist.title')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('tripChecklist.breadcrumb'), key: 'trip-checklist' },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu slot="trip-context-action" locale={locale} fallbackHref={dashboardUrl} />
    <div slot="body" class="pt-6">
      <section
        class="mb-6 rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-4 py-4 shadow-[var(--shadow-xs)]"
        data-parent-trip-banner
        hidden
      >
        <p class="text-xs font-black uppercase tracking-[0.14em] text-[var(--color-text-soft)]">{t('trip.miniTrips.parentEyebrow')}</p>
        <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
          <p class="text-sm text-[var(--color-text-muted)]">
            {t('trip.miniTrips.parentDescription')}
            <a class="font-bold text-[var(--color-primary)]" data-parent-trip-link href="#">
              <span data-parent-trip-name></span>
            </a>
          </p>
          <a class="app-card-link" data-parent-trip-action hidden href="#">{t('trip.miniTrips.backToParent')}</a>
        </div>
      </section>
      <div class="flex flex-wrap gap-3 text-sm font-semibold text-[var(--color-text-muted)]">
        <span class="status-pill" data-tone="warning" data-checklist-pending-count>0</span>
        <span class="status-pill" data-tone="success" data-checklist-completed-count>0</span>
      </div>
      <form class="mt-6 grid gap-3 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-end" id="trip-checklist-form">
        <ChecklistItemFormFields locale={locale} prefix="trip-checklist" />
        <Button type="submit">{t('tripChecklist.form.addShort')}</Button>
        <p class="text-sm text-[var(--color-text-soft)] sm:col-span-2" id="trip-checklist-message" role="status" aria-live="polite"></p>
      </form>
      <div class="mt-8 border-t border-[var(--color-border)] pt-8">
        <div class="grid gap-4" data-checklist-list>
          <LoadingState label={t('common.loading')} />
        </div>
      </div>
    </div>
  </AppShell>
  <script>
    import { mountTripChecklistPage } from '../../scripts/pages/trip-checklist';

    mountTripChecklistPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
