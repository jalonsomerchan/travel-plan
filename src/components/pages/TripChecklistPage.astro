---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppBackButton from '../app/AppBackButton.astro';
import AppShell from '../app/AppShell.astro';
import ChecklistItemFormFields from '../app/ChecklistItemFormFields.astro';
import LoadingState from '../app/LoadingState.astro';
import Button from '../Button.astro';
import Container from '../Container.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('tripChecklist.metaTitle')} description={t('tripChecklist.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('tripChecklist.eyebrow')}
    title={t('tripChecklist.title')}
    description={t('tripChecklist.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('tripChecklist.breadcrumb'), key: 'trip-checklist' },
    ]}
  >
    <div slot="topbar" class="app-shell-topbar-row">
      <AppBackButton fallbackHref={dashboardUrl} label={t('common.goBack')} />
      <div>
        <Button id="trip-checklist-back-link" href={dashboardUrl} variant="ghost">
          {t('tripChecklist.backToTrip')}
        </Button>
      </div>
    </div>
  </AppShell>
  <Container class="pb-12">
    <section class="section-shell mx-auto max-w-4xl px-6 py-6 md:px-8">
      <h2 class="text-2xl font-black" data-trip-context>{t('tripChecklist.sectionTitle')}</h2>
      <div class="mt-4 flex flex-wrap gap-3 text-sm font-semibold text-[var(--color-text-muted)]">
        <span class="status-pill" data-tone="warning" data-checklist-pending-count>0</span>
        <span class="status-pill" data-tone="success" data-checklist-completed-count>0</span>
      </div>
      <form class="mt-6 space-y-4" id="trip-checklist-form">
        <ChecklistItemFormFields locale={locale} prefix="trip-checklist" />
        <p class="text-sm text-[var(--color-text-soft)]" id="trip-checklist-message">
          {t('tripChecklist.form.helper')}
        </p>
        <div class="flex flex-wrap gap-3">
          <Button type="submit">{t('tripChecklist.form.add')}</Button>
        </div>
      </form>
      <div class="mt-8 border-t border-[var(--color-border)] pt-8">
        <div class="grid gap-4" data-checklist-list>
          <LoadingState label={t('common.loading')} />
        </div>
      </div>
    </section>
  </Container>
  <script>
    import { mountTripChecklistPage } from '../../scripts/pages/trip-checklist';

    mountTripChecklistPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
