---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import Button from '../Button.astro';
import LoadingState from '../app/LoadingState.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import TripSectionNav from '../app/TripSectionNav.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('tripAiPrompt.metaTitle')} description={t('tripAiPrompt.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('tripAiPrompt.eyebrow')}
    title={t('tripAiPrompt.title')}
    description={t('tripAiPrompt.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('tripAiPrompt.breadcrumb') },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <TripSectionNav slot="nav" locale={locale} fallbackHref={dashboardUrl} />

    <div slot="body" class="pt-6">
      <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_minmax(20rem,0.8fr)]">
        <section class="space-y-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-5 md:p-6" aria-labelledby="trip-ai-prompt-title">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <span class="eyebrow">{t('tripAiPrompt.prompt.eyebrow')}</span>
              <h2 class="mt-3 text-2xl font-black text-[var(--color-text)]" id="trip-ai-prompt-title">
                {t('tripAiPrompt.prompt.title')}
              </h2>
            </div>
            <span class="status-pill" data-tone="primary">{t('tripAiPrompt.prompt.badge')}</span>
          </div>
          <p class="text-sm text-[var(--color-text-soft)]">{t('tripAiPrompt.prompt.helper')}</p>
          <div>
            <label class="field-label" for="trip-ai-prompt-output">{t('tripAiPrompt.prompt.label')}</label>
            <textarea
              class="field-textarea min-h-96 font-mono text-xs leading-relaxed"
              data-trip-ai-prompt-output
              id="trip-ai-prompt-output"
              readonly
              spellcheck="false"
            >{t('common.loading')}</textarea>
          </div>
          <div class="flex flex-wrap gap-3">
            <Button data-trip-ai-prompt-copy type="button">{t('tripAiPrompt.prompt.copy')}</Button>
            <Button data-trip-ai-prompt-chatgpt href="https://chatgpt.com/" rel="noopener noreferrer" target="_blank" variant="secondary">
              {t('tripAiPrompt.prompt.openChatGpt')}
            </Button>
          </div>
          <p class="text-sm text-[var(--color-text-soft)]" data-trip-ai-prompt-message>
            {t('tripAiPrompt.prompt.copyHelper')}
          </p>
        </section>

        <section class="space-y-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-5 md:p-6" aria-labelledby="trip-ai-json-title">
          <div>
            <span class="eyebrow">{t('tripAiPrompt.import.eyebrow')}</span>
            <h2 class="mt-3 text-2xl font-black text-[var(--color-text)]" id="trip-ai-json-title">
              {t('tripAiPrompt.import.title')}
            </h2>
          </div>
          <p class="text-sm text-[var(--color-text-soft)]">{t('tripAiPrompt.import.helper')}</p>
          <form class="space-y-4" data-trip-ai-import-form>
            <div>
              <label class="field-label" for="trip-ai-json-input">{t('tripAiPrompt.import.label')}</label>
              <textarea
                class="field-textarea min-h-64 font-mono text-xs leading-relaxed"
                id="trip-ai-json-input"
                name="json"
                placeholder={t('tripAiPrompt.import.placeholder')}
                spellcheck="false"
              ></textarea>
            </div>
            <Button type="submit" variant="secondary">{t('tripAiPrompt.import.parse')}</Button>
          </form>
          <p class="text-sm text-[var(--color-text-soft)]" data-trip-ai-import-message>
            {t('tripAiPrompt.import.empty')}
          </p>
        </section>
      </div>

      <section class="mt-8 border-t border-[var(--color-border)] pt-8" aria-labelledby="trip-ai-candidates-title">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <span class="eyebrow">{t('tripAiPrompt.candidates.eyebrow')}</span>
            <h2 class="mt-3 text-2xl font-black text-[var(--color-text)]" id="trip-ai-candidates-title">
              {t('tripAiPrompt.candidates.title')}
            </h2>
          </div>
          <span class="status-pill" data-trip-ai-candidates-count data-tone="warning">0</span>
        </div>
        <div class="mt-5 grid gap-4" data-trip-ai-candidates-list>
          <LoadingState label={t('common.loading')} />
        </div>
        <div class="mt-5 flex flex-wrap gap-3" data-trip-ai-candidates-actions hidden>
          <Button data-trip-ai-save-selected type="button">{t('tripAiPrompt.candidates.saveSelected')}</Button>
        </div>
      </section>
    </div>
  </AppShell>

  <script>
    import { mountTripAiPromptPage } from '../../scripts/pages/trip-ai-prompt';

    mountTripAiPromptPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
