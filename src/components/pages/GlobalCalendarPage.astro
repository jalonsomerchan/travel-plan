---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import AppToolbar from '../app/AppToolbar.astro';
import LoadingState from '../app/LoadingState.astro';
import Button from '../Button.astro';
import Container from '../Container.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('calendar.globalMetaTitle')} description={t('calendar.globalMetaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('calendar.globalEyebrow')}
    title={t('calendar.globalTitle')}
    description={t('calendar.globalDescription')}
    breadcrumbs={[{ label: t('nav.home'), href: getLocalizedPath('/', locale) }, { label: t('dashboard.breadcrumb'), href: dashboardUrl }, { label: t('calendar.globalBreadcrumb') }]}
  >
    <AppToolbar>
      <div slot="secondary">
        <Button href={dashboardUrl} variant="ghost">{t('calendar.backToDashboard')}</Button>
      </div>
    </AppToolbar>
  </AppShell>

  <Container class="pb-12">
    <section class="section-shell px-6 py-6 md:px-8">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="min-w-0">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)]">{t('calendar.overviewLabel')}</p>
          <h2 class="mt-3 text-3xl font-black capitalize" data-global-month-label></h2>
        </div>
        <div class="flex items-center gap-2">
          <Button id="global-calendar-prev-month" variant="secondary" type="button">{t('calendar.previous')}</Button>
          <Button id="global-calendar-next-month" variant="secondary" type="button">{t('calendar.next')}</Button>
        </div>
      </div>
      <div class="mt-6 grid grid-cols-7 gap-2 text-center text-xs font-bold uppercase tracking-[0.14em] text-[var(--color-text-soft)]" data-global-weekdays></div>
      <div class="mt-3 grid grid-cols-7 gap-2" data-global-calendar-grid></div>
        </div>

        <div class="min-w-0 border-t border-[var(--color-border)] pt-8 lg:border-t-0 lg:border-l lg:pl-8 lg:pt-0">
      <div>
        <span class="eyebrow">{t('calendar.timelineEyebrow')}</span>
        <h2 class="mt-4 text-2xl font-black">{t('calendar.timelineTitle')}</h2>
      </div>
      <div class="mt-6 grid gap-4" data-global-events>
        <LoadingState label={t('common.loading')} />
      </div>
        </div>
      </div>
    </section>
  </Container>

  <script>
    import { mountGlobalCalendarPage } from '../../scripts/pages/global-calendar';

    mountGlobalCalendarPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
