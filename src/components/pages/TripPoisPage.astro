---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import LocationPickerFields from '../app/LocationPickerFields.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import TripSectionNav from '../app/TripSectionNav.astro';
import Button from '../Button.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('tripPois.metaTitle')} description={t('tripPois.metaDescription')} locale={locale}>
  <AppShell
    title={t('tripPois.title')}
    description={t('tripPois.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('tripPois.breadcrumb'), key: 'trip-pois' },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <TripSectionNav slot="nav" locale={locale} fallbackHref={dashboardUrl} />
    <div slot="body" class="pt-6">
      <form class="grid gap-5" id="trip-poi-form">
        <input name="pointId" type="hidden" />
        <div class="grid gap-4 md:grid-cols-[1fr_12rem]">
          <label class="grid gap-2">
            <span class="field-label">{t('tripPois.form.name')}</span>
            <input class="field-input" name="name" required />
          </label>
          <label class="grid gap-2">
            <span class="field-label">{t('tripPois.form.icon')}</span>
            <select class="field-select" name="icon">
              <option value="star">★ {t('tripPois.icon.star')}</option>
              <option value="camera">● {t('tripPois.icon.camera')}</option>
              <option value="food">● {t('tripPois.icon.food')}</option>
              <option value="view">● {t('tripPois.icon.view')}</option>
              <option value="pin">● {t('tripPois.icon.pin')}</option>
            </select>
          </label>
        </div>
        <LocationPickerFields
          clearButtonName={t('plan.location.clear')}
          helperKey="tripPois.form.locationHelper"
          latFieldName="locationLat"
          locale={locale}
          lngFieldName="locationLng"
          nameFieldName="locationName"
          prefix="trip-poi"
          queryFieldLabel={t('tripPois.form.location')}
          queryFieldName="locationQuery"
          searchButtonName={t('plan.location.search')}
        />
        <p class="text-sm text-[var(--color-text-soft)]" id="trip-poi-message" role="status" aria-live="polite">
          {t('tripPois.form.helper')}
        </p>
        <div class="flex flex-wrap gap-3">
          <Button type="submit">{t('tripPois.form.save')}</Button>
          <Button data-trip-poi-cancel-edit hidden type="button" variant="secondary">{t('common.cancel')}</Button>
        </div>
      </form>
      <div class="mt-8 border-t border-[var(--color-border)] pt-8">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <h2 class="text-2xl font-black">{t('tripPois.listTitle')}</h2>
          <span class="status-pill" data-tone="primary" data-trip-poi-count>0</span>
        </div>
        <div class="mt-6 grid gap-4" data-trip-poi-list></div>
      </div>
    </div>
  </AppShell>

  <script>
    import { mountTripPoisPage } from '../../scripts/pages/trip-pois';

    mountTripPoisPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
