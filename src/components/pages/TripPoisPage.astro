---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import TripPoiFormDialog from '../app/TripPoiFormDialog.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import TripSectionNav from '../app/TripSectionNav.astro';
import Button from '../Button.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('tripPois.metaTitle')} description={t('tripPois.metaDescription')} locale={locale}>
  <AppShell
    title={t('tripPois.title')}
    description={t('tripPois.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('tripPois.breadcrumb'), key: 'trip-pois' },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <TripSectionNav slot="nav" locale={locale} fallbackHref={dashboardUrl} />
    <div slot="body" class="pt-6">
      <div class="flex flex-wrap items-center justify-between gap-3 border-b border-[var(--color-border)] pb-5">
        <div class="min-w-0">
          <h2 class="text-2xl font-black">{t('tripPois.listTitle')}</h2>
          <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripPois.listDescription')}</p>
        </div>
        <div class="flex items-center gap-3">
          <span class="status-pill" data-tone="primary" data-trip-poi-count>0</span>
          <Button data-trip-poi-ai-link href={dashboardUrl} variant="secondary" type="button">{t('tripPois.createAiAction')}</Button>
          <Button data-trip-poi-open-create type="button">{t('tripPois.createAction')}</Button>
        </div>
      </div>
      <p class="mt-4 text-sm text-[var(--color-text-soft)]" id="trip-poi-page-message" role="status" aria-live="polite">
        {t('tripPois.form.helper')}
      </p>
      <div class="mt-6 grid gap-4" data-trip-poi-list></div>
      <div class="app-snackbar" aria-live="polite" data-trip-poi-snackbar hidden></div>
      <TripPoiFormDialog locale={locale} />
    </div>
  </AppShell>

  <script>
    import { mountTripPoisPage } from '../../scripts/pages/trip-pois';

    mountTripPoisPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
