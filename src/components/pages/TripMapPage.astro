---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import LoadingState from '../app/LoadingState.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import TripSectionNav from '../app/TripSectionNav.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('map.metaTitle')} description={t('map.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('map.eyebrow')}
    title={t('map.title')}
    description={t('map.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('map.breadcrumb') },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <TripSectionNav slot="nav" locale={locale} fallbackHref={dashboardUrl} />
    <div slot="body" class="pt-6">
      <div class="min-w-0">
        <div class="flex justify-end">
          <span class="status-pill" data-tone="primary" data-map-count>0</span>
        </div>
        <div class="mt-3 overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-raised)]">
          <div class="trip-map-canvas trip-map-canvas--wide" data-trip-map-canvas aria-label={t('map.canvasTitle')}></div>
        </div>
      </div>
      <div class="mt-8 min-w-0 border-t border-[var(--color-border)] pt-8">
        <div>
          <h2 class="text-2xl font-black">{t('map.listTitle')}</h2>
        </div>
        <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3" data-map-plan-list>
          <LoadingState label={t('common.loading')} />
        </div>
      </div>
    </div>
  </AppShell>

  <script>
    import { mountTripMapPage } from '../../scripts/pages/trip-map';

    mountTripMapPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
