---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import AppToolbar from '../app/AppToolbar.astro';
import LoadingState from '../app/LoadingState.astro';
import Button from '../Button.astro';
import Container from '../Container.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('map.metaTitle')} description={t('map.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('map.eyebrow')}
    title={t('map.title')}
    description={t('map.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('map.breadcrumb') },
    ]}
  >
    <AppToolbar>
      <div slot="secondary">
        <Button id="map-back-trip-link" variant="ghost" href={dashboardUrl}>{t('map.backToTrip')}</Button>
        <Button id="map-calendar-link" variant="ghost" href={dashboardUrl}>{t('map.openCalendar')}</Button>
      </div>
    </AppToolbar>
  </AppShell>

  <Container class="grid gap-8 pb-12 lg:grid-cols-[1.18fr_0.82fr]">
    <section class="section-shell overflow-hidden px-6 py-6">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)]" data-map-trip-name aria-live="polite">
            <span class="sr-only">{t('common.loading')}</span>
          </p>
          <h2 class="mt-3 text-3xl font-black">{t('map.canvasTitle')}</h2>
        </div>
        <span class="status-pill" data-tone="primary" data-map-count>0</span>
      </div>
      <div class="mt-6 overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-raised)]">
        <div class="trip-map-canvas" data-trip-map-canvas aria-label={t('map.canvasTitle')}></div>
      </div>
    </section>

    <aside class="section-shell px-6 py-6">
      <div>
        <span class="eyebrow">{t('map.listEyebrow')}</span>
        <h2 class="mt-4 text-2xl font-black">{t('map.listTitle')}</h2>
      </div>
      <div class="mt-6 grid gap-4" data-map-plan-list>
        <LoadingState label={t('common.loading')} />
      </div>
    </aside>
  </Container>

  <script>
    import { mountTripMapPage } from '../../scripts/pages/trip-map';

    mountTripMapPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>