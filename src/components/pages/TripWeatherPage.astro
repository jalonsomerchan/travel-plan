---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import LoadingState from '../app/LoadingState.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('weather.metaTitle')} description={t('weather.metaDescription')} locale={locale}>
  <AppShell
    tripContext
    eyebrow={t('weather.eyebrow')}
    title={t('weather.title')}
    description={t('weather.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('weather.breadcrumb'), key: 'trip-weather' },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu slot="trip-context-action" locale={locale} fallbackHref={dashboardUrl} />

    <div slot="body" class="pt-6">
      <div class="grid gap-6">
        <section class="trip-weather-panel">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
            <div>
              <span class="eyebrow">{t('weather.tabEyebrow')}</span>
              <h2 class="mt-3 text-2xl font-black">{t('weather.tabTitle')}</h2>
            </div>
            <p class="max-w-2xl text-sm text-[var(--color-text-soft)]">{t('weather.tabHelper')}</p>
          </div>
          <div class="trip-weather-tabs mt-6" data-weather-year-tabs>
            <LoadingState label={t('common.loading')} />
          </div>
        </section>

        <section class="trip-weather-panel">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <span class="eyebrow">{t('weather.daysEyebrow')}</span>
              <h2 class="mt-3 text-2xl font-black">{t('weather.daysTitle')}</h2>
            </div>
            <p class="text-sm font-semibold text-[var(--color-text-soft)]" data-weather-range-label>{t('common.loading')}</p>
          </div>
          <div class="mt-6 grid gap-4" data-weather-days>
            <LoadingState label={t('common.loading')} />
          </div>
        </section>
      </div>
    </div>
  </AppShell>

  <style is:global>
    .trip-weather-panel {
      border-radius: var(--radius-lg);
      border: 1px solid var(--color-border);
      background:
        linear-gradient(180deg, color-mix(in srgb, var(--color-surface-raised), transparent 5%), var(--color-surface-raised)),
        radial-gradient(circle at top right, color-mix(in srgb, var(--color-primary-soft), transparent 20%), transparent 45%);
      padding: 1rem;
    }

    .trip-weather-tabs {
      display: flex;
      gap: 0.65rem;
      max-width: 100%;
      overflow-x: auto;
      padding-bottom: 0.15rem;
      scrollbar-width: thin;
    }

    .trip-weather-tab {
      flex: 0 0 auto;
      min-height: 2.45rem;
      border-radius: 999px;
      border: 1px solid var(--color-border);
      background: var(--color-surface-soft);
      padding: 0.55rem 0.85rem;
      font-size: 0.88rem;
      font-weight: 800;
      color: var(--color-text-muted);
      transition:
        background var(--transition-base, 180ms ease),
        color var(--transition-base, 180ms ease),
        border-color var(--transition-base, 180ms ease);
    }

    .trip-weather-tab[aria-selected="true"] {
      border-color: color-mix(in srgb, var(--color-primary), transparent 40%);
      background: color-mix(in srgb, var(--color-primary-soft), var(--color-surface-raised) 35%);
      color: var(--color-text);
    }

    .trip-weather-day-accordion {
      overflow: hidden;
      border-radius: var(--radius-lg);
      border: 1px solid var(--color-border);
      background: var(--color-surface-raised);
    }

    .trip-weather-day-accordion[open] {
      border-color: color-mix(in srgb, var(--color-primary), transparent 30%);
      box-shadow: var(--shadow-xs);
    }

    .trip-weather-day-summary-button {
      width: 100%;
      list-style: none;
      cursor: pointer;
      padding: 0.8rem 0.9rem;
      text-align: left;
    }

    .trip-weather-day-summary-button::-webkit-details-marker {
      display: none;
    }

    .trip-weather-day-summary,
    .trip-weather-hour-summary {
      margin: 0;
      color: var(--color-text-muted);
      font-size: 0.96rem;
      font-weight: 800;
      line-height: 1.1;
    }

    .trip-weather-day-main {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.75rem;
      margin-top: 0.55rem;
    }

    .trip-weather-day-temperatures,
    .trip-weather-hour-temperatures {
      display: grid;
      gap: 0.15rem;
      justify-items: end;
      text-align: right;
    }

    .trip-weather-day-temperatures--inline,
    .trip-weather-hour-temperatures--inline {
      display: inline-flex;
      align-items: baseline;
      gap: 0.35rem;
      white-space: nowrap;
    }

    .trip-weather-day-temperatures strong,
    .trip-weather-day-temperatures em,
    .trip-weather-hour-temperatures strong,
    .trip-weather-hour-temperatures em {
      font-size: 0.96rem;
      font-style: normal;
      font-weight: 800;
      line-height: 1.1;
    }

    .trip-weather-day-temperatures strong,
    .trip-weather-hour-temperatures strong {
      color: var(--color-danger);
    }

    .trip-weather-day-temperatures span,
    .trip-weather-hour-temperatures span {
      color: var(--color-text-soft);
      font-size: 0.8rem;
      font-weight: 700;
    }

    .trip-weather-day-temperatures em,
    .trip-weather-hour-temperatures em {
      color: var(--color-info);
    }

    .trip-weather-day-copy,
    .trip-weather-hour-copy {
      min-width: 0;
    }

    .trip-weather-day-topline {
      display: flex;
      align-items: start;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .trip-weather-day-chevron {
      color: var(--color-text-soft);
      font-size: 1rem;
      line-height: 1;
      transition: transform var(--transition-base, 180ms ease);
    }

    .trip-weather-day-accordion[open] .trip-weather-day-chevron {
      transform: rotate(90deg);
    }

    .trip-weather-day-hours {
      border-top: 1px solid var(--color-border);
      padding: 0 0.9rem 0.9rem;
    }

    .trip-weather-hour-card {
      border-radius: var(--radius-md);
      border: 1px solid var(--color-border);
      background: var(--color-surface-raised);
      padding: 0.7rem 0.8rem;
      min-width: 0;
    }

    .trip-weather-hour-grid {
      display: grid;
      gap: 0.55rem;
      grid-template-columns: minmax(0, 1fr);
      align-items: start;
    }

    .trip-weather-hour-main {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
      gap: 0.75rem;
    }

    .trip-weather-hour-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem 0.7rem;
      margin-top: 0.55rem;
      color: var(--color-text-soft);
      font-size: 0.8rem;
      font-weight: 600;
    }

    .trip-weather-empty {
      border-radius: var(--radius-lg);
      border: 1px dashed var(--color-border);
      background: var(--color-surface-soft);
      padding: 1.1rem;
      color: var(--color-text-soft);
      text-align: center;
    }

    .weather-icon-svg {
      width: 3.2rem;
      height: 3.2rem;
      flex-shrink: 0;
    }

    @media (max-width: 47.99rem) {
      .trip-weather-panel {
        min-width: 0;
        overflow-x: clip;
        padding: 0.9rem;
      }

      .trip-weather-day-main {
        align-items: center;
      }

      .trip-weather-hour-main {
        grid-template-columns: auto minmax(0, 1fr);
      }

      .trip-weather-hour-temperatures {
        grid-column: 1 / -1;
        justify-items: start;
        text-align: left;
        padding-left: calc(3.2rem + 0.75rem);
      }

      .trip-weather-hour-meta {
        flex-direction: column;
        align-items: start;
      }
    }

    @media (min-width: 48rem) {
      .trip-weather-panel {
        padding: 1.2rem;
      }
    }
  </style>

  <script>
    import { mountTripWeatherPage } from '../../scripts/pages/trip-weather';

    mountTripWeatherPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
