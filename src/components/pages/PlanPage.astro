---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import LoadingState from '../app/LoadingState.astro';
import NearbyPoiExplorer from '../app/NearbyPoiExplorer.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import TripSectionNav from '../app/TripSectionNav.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('plan.metaTitle')} description={t('plan.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('plan.eyebrow')}
    title={t('plan.title')}
    description={t('plan.description')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('plan.breadcrumb'), key: 'plan' },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <TripSectionNav slot="nav" locale={locale} fallbackHref={dashboardUrl} />
    <div slot="body" class="pt-6">
      <div class="mb-6 flex flex-wrap gap-3">
        <a
          class="app-card-link"
          data-plan-edit-visible-link
          data-variant="secondary"
          href={dashboardUrl}
        >
          {t('plan.goEdit')}
        </a>
        <button class="app-card-link" data-plan-ai-tour-open data-variant="secondary" type="button">
          {t('plan.aiTour.open')}
        </button>
        <button class="app-card-link" data-plan-delete-button data-variant="danger" type="button">
          {t('plan.delete')}
        </button>
      </div>
      <p class="mb-6 text-sm text-[var(--color-text-soft)]" data-plan-delete-message>{t('plan.deleteHelper')}</p>

      <dialog class="plan-ai-tour-modal w-[min(100%-1.5rem,56rem)] max-w-none overflow-hidden rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] p-0 text-[var(--color-text)] shadow-[var(--shadow-lg)]" data-plan-ai-tour-modal>
        <div class="max-h-[min(88vh,56rem)] overflow-y-auto p-4 md:p-6">
          <div class="relative space-y-5">
            <button
              aria-label={t('plan.aiTour.closeLabel')}
              class="absolute right-0 top-0 inline-flex h-11 w-11 items-center justify-center rounded-full border border-[var(--color-border)] bg-[var(--color-surface-soft)] text-xl font-bold text-[var(--color-text)] shadow-[var(--shadow-xs)] transition hover:bg-[var(--color-surface)]"
              data-plan-ai-tour-close
              type="button"
            >
              <span aria-hidden="true">×</span>
            </button>

            <div class="flex flex-wrap items-start justify-between gap-4 pr-14">
            <div>
              <span class="eyebrow">{t('plan.aiTour.eyebrow')}</span>
              <h2 class="mt-3 text-2xl font-black text-[var(--color-text)]">{t('plan.aiTour.title')}</h2>
              <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('plan.aiTour.helper')}</p>
            </div>
          </div>

          <div class="grid gap-4 xl:grid-cols-3">
            <fieldset class="space-y-3">
              <legend class="field-label">{t('plan.aiTour.tone')}</legend>
              <label class="flex gap-3 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-3 text-sm">
                <input checked name="planAiTourTone" type="radio" value="serious" />
                <span>{t('plan.aiTour.tone.serious')}</span>
              </label>
              <label class="flex gap-3 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-3 text-sm">
                <input name="planAiTourTone" type="radio" value="fun" />
                <span>{t('plan.aiTour.tone.fun')}</span>
              </label>
              <label class="flex gap-3 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-3 text-sm">
                <input name="planAiTourTone" type="radio" value="storyteller" />
                <span>{t('plan.aiTour.tone.storyteller')}</span>
              </label>
            </fieldset>

            <fieldset class="space-y-3">
              <legend class="field-label">{t('plan.aiTour.length')}</legend>
              <label class="flex gap-3 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-3 text-sm">
                <input checked name="planAiTourLength" type="radio" value="standard" />
                <span>{t('plan.aiTour.length.standard')}</span>
              </label>
              <label class="flex gap-3 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-3 text-sm">
                <input name="planAiTourLength" type="radio" value="short" />
                <span>{t('plan.aiTour.length.short')}</span>
              </label>
              <label class="flex gap-3 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-3 text-sm">
                <input name="planAiTourLength" type="radio" value="detailed" />
                <span>{t('plan.aiTour.length.detailed')}</span>
              </label>
            </fieldset>

            <fieldset class="space-y-3">
              <legend class="field-label">{t('plan.aiTour.focus')}</legend>
              <label class="flex gap-3 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-3 text-sm">
                <input checked name="planAiTourFocus" type="radio" value="mixed" />
                <span>{t('plan.aiTour.focus.mixed')}</span>
              </label>
              <label class="flex gap-3 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-3 text-sm">
                <input name="planAiTourFocus" type="radio" value="history" />
                <span>{t('plan.aiTour.focus.history')}</span>
              </label>
              <label class="flex gap-3 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-3 text-sm">
                <input name="planAiTourFocus" type="radio" value="practical" />
                <span>{t('plan.aiTour.focus.practical')}</span>
              </label>
            </fieldset>
          </div>

          <div>
            <label class="field-label" for="plan-ai-tour-prompt-output">{t('plan.aiTour.promptLabel')}</label>
            <textarea
              class="field-textarea min-h-80 font-mono text-xs leading-relaxed"
              data-plan-ai-tour-output
              id="plan-ai-tour-prompt-output"
              readonly
              spellcheck="false"
            >{t('common.loading')}</textarea>
          </div>

          <div class="flex flex-wrap gap-3">
            <button class="app-card-link" data-plan-ai-tour-copy data-variant="primary" type="button">
              {t('plan.aiTour.copy')}
            </button>
            <a class="app-card-link" data-plan-ai-tour-chatgpt data-variant="secondary" href="https://chatgpt.com/" rel="noopener noreferrer" target="_blank">
              {t('plan.aiTour.openChatGpt')}
            </a>
          </div>

          <p class="text-sm text-[var(--color-text-soft)]" data-plan-ai-tour-message>{t('plan.aiTour.copyHelper')}</p>
        </div>
      </dialog>

      <dl class="grid gap-4">
        <div>
          <dt class="text-xs font-semibold uppercase tracking-[0.14em] text-[var(--color-text-soft)]">
            {t('plan.form.description')}
          </dt>
          <dd class="mt-1 text-base text-[var(--color-text)]" data-plan-description>
            {t('common.loading')}
          </dd>
        </div>
        <div data-plan-map-section hidden>
          <div class="mt-4 overflow-hidden rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)]">
            <div class="h-[30rem] w-full" data-plan-map aria-label={t('map.canvasTitle')}></div>
          </div>
          <div class="mt-4 flex flex-wrap gap-3">
            <a class="app-card-link" data-plan-open-osm data-variant="secondary" href="#" rel="noopener noreferrer" target="_blank">
              {t('poi.openStreetMap')}
            </a>
            <a class="app-card-link" data-plan-open-google data-variant="secondary" href="#" rel="noopener noreferrer" target="_blank">
              {t('plan.location.openMap')}
            </a>
            <a class="app-card-link" data-plan-open-directions data-variant="primary" href="#" rel="noopener noreferrer" target="_blank">
              {t('plan.location.getDirections')}
            </a>
          </div>
        </div>
      </dl>
      <section
        class="mt-6 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-4"
        data-plan-ai-guide-section
        hidden
        aria-labelledby="plan-ai-guide-title"
      >
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-[var(--color-text-soft)]" id="plan-ai-guide-title">
              {t('plan.aiGuide.title')}
            </h3>
            <p class="mt-1 text-sm text-[var(--color-text-soft)]">{t('plan.aiGuide.description')}</p>
          </div>
          <span class="status-pill" data-tone="primary">{t('plan.aiGuide.badge')}</span>
        </div>
        <p class="mt-4 whitespace-pre-line text-base text-[var(--color-text)]" data-plan-ai-guide-text></p>
        <div class="mt-4 flex flex-wrap gap-3">
          <button class="app-card-link" data-plan-ai-guide-play data-variant="primary" type="button">
            {t('plan.aiGuide.play')}
          </button>
          <button class="app-card-link" data-plan-ai-guide-stop data-variant="secondary" type="button">
            {t('plan.aiGuide.stop')}
          </button>
        </div>
        <p class="mt-3 text-sm text-[var(--color-text-soft)]" data-plan-ai-guide-message>
          {t('plan.aiGuide.helper')}
        </p>
      </section>
      <section
        class="mt-6 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-4"
        data-plan-links-section
        hidden
        aria-labelledby="plan-links-title"
      >
        <h3 class="text-sm font-bold uppercase tracking-[0.14em] text-[var(--color-text-soft)]" id="plan-links-title">
          {t('plan.links.title')}
        </h3>
        <p class="mt-1 text-sm text-[var(--color-text-soft)]">{t('plan.links.description')}</p>
        <ul class="mt-4 grid gap-2" data-plan-links-list></ul>
      </section>
      <NearbyPoiExplorer
        locale={locale}
        title={t('poi.plan.title')}
        description={t('poi.plan.description')}
        emptyActionLabel={t('poi.plan.addLocationAction')}
        tripId=""
      />
    </div>
  </AppShell>
  <script>
    import { mountPlanPage } from '../../scripts/pages/plan';

    mountPlanPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
