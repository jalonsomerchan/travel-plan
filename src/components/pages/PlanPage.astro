---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import Button from '../Button.astro';
import Container from '../Container.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('plan.metaTitle')} description={t('plan.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('plan.eyebrow')}
    title={t('plan.title')}
    description={t('plan.description')}
    breadcrumbs={[{ label: t('nav.home'), href: getLocalizedPath('/', locale) }, { label: t('dashboard.breadcrumb'), href: dashboardUrl }, { label: t('trip.breadcrumb') }, { label: t('plan.breadcrumb') }]}
  >
    <div class="mt-8 flex flex-wrap gap-3">
      <Button id="plan-back-trip-link" variant="secondary" href={dashboardUrl}>{t('plan.backToTrip')}</Button>
      <Button id="plan-edit-link" href={dashboardUrl}>{t('plan.goEdit')}</Button>
    </div>
  </AppShell>
  <Container class="pb-12">
    <section class="section-shell mx-auto max-w-3xl px-6 py-6">
      <div data-plan-view>
        <article class="rounded-[var(--radius-lg)] border border-dashed border-[var(--color-border)] bg-[var(--color-surface-soft)] px-5 py-8 text-center text-sm text-[var(--color-text-soft)]">
          {t('common.loading')}
        </article>
      </div>
    </section>
  </Container>
  <script>
    import { mountPlanPage } from '../../scripts/pages/plan';

    mountPlanPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
