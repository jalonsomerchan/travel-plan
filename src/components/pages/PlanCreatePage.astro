---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import TripSectionNav from '../app/TripSectionNav.astro';
import Button from '../Button.astro';
import PlanFormFields from '../app/PlanFormFields.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('planCreate.metaTitle')} description={t('planCreate.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('planCreate.eyebrow')}
    title={t('planCreate.title')}
    description={t('planCreate.description')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('planCreate.breadcrumb') },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <TripSectionNav slot="nav" locale={locale} fallbackHref={dashboardUrl} />
    <div slot="body" class="pt-6">
      <h2 class="text-2xl font-black" data-plan-create-context>{t('trip.plansTitle')}</h2>
      <form class="mt-6 w-full space-y-4" id="plan-create-form">
        <PlanFormFields locale={locale} prefix="plan-create" />
        <p class="text-sm text-[var(--color-text-soft)]" id="plan-create-message" role="status" aria-live="polite">{t('trip.plansHelper')}</p>
        <div class="flex flex-wrap gap-3">
          <Button type="submit">{t('trip.plansAction')}</Button>
        </div>
      </form>
    </div>
  </AppShell>
  <script>
    import { mountPlanCreatePage } from '../../scripts/pages/plan-create';

    mountPlanCreatePage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
