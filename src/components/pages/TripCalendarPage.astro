---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import LoadingState from '../app/LoadingState.astro';
import TripActionsMenu from '../app/TripActionsMenu.astro';
import TripNavigationTopbar from '../app/TripNavigationTopbar.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('calendar.tripMetaTitle')} description={t('calendar.tripMetaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('calendar.tripEyebrow')}
    title={t('calendar.tripTitle')}
    description={t('calendar.tripDescription')}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('calendar.breadcrumb') },
    ]}
  >
    <TripNavigationTopbar slot="topbar" locale={locale} fallbackHref={dashboardUrl} />
    <TripActionsMenu locale={locale} fallbackHref={dashboardUrl} />
    <div slot="body" class="pt-6">
      <div class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="min-w-0">
          <div>
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)]" data-calendar-trip-name aria-live="polite">
                <span class="sr-only">{t('common.loading')}</span>
              </p>
              <h2 class="mt-3 text-3xl font-black">{t('calendar.timelineTitle')}</h2>
            </div>
          </div>
          <div class="mt-6 grid gap-4" data-trip-calendar-groups>
            <LoadingState label={t('common.loading')} />
          </div>
        </div>

        <div class="min-w-0 border-t border-[var(--color-border)] pt-8 lg:border-t-0 lg:border-l lg:pl-8 lg:pt-0">
          <div>
            <span class="eyebrow">{t('calendar.unscheduledEyebrow')}</span>
            <h2 class="mt-4 text-2xl font-black">{t('calendar.unscheduledTitle')}</h2>
          </div>
          <div class="mt-6 grid gap-4" data-calendar-events>
            <LoadingState label={t('common.loading')} />
          </div>
        </div>
      </div>
    </div>
  </AppShell>

  <script>
    import { mountTripCalendarPage } from '../../scripts/pages/trip-calendar';

    mountTripCalendarPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
