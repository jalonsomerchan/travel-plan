---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppShell from '../app/AppShell.astro';
import AppToolbar from '../app/AppToolbar.astro';
import Button from '../Button.astro';
import Container from '../Container.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('calendar.tripMetaTitle')} description={t('calendar.tripMetaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('calendar.tripEyebrow')}
    title={t('calendar.tripTitle')}
    description={t('calendar.tripDescription')}
    breadcrumbs={[
      { label: t('nav.home'), href: getLocalizedPath('/', locale) },
      { label: t('dashboard.breadcrumb'), href: dashboardUrl },
      { label: t('trip.breadcrumb'), key: 'trip' },
      { label: t('calendar.breadcrumb') },
    ]}
  >
    <AppToolbar>
      <div slot="secondary">
        <Button id="calendar-back-trip-link" variant="ghost" href={dashboardUrl}>{t('calendar.backToTrip')}</Button>
      </div>
    </AppToolbar>
  </AppShell>

  <Container class="grid gap-8 pb-12 lg:grid-cols-[1.2fr_0.8fr]">
    <section class="section-shell px-6 py-6">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.16em] text-[var(--color-primary)]" data-calendar-trip-name>
            {t('common.loading')}
          </p>
          <h2 class="mt-3 text-3xl font-black capitalize" data-month-label></h2>
        </div>
        <div class="flex items-center gap-2">
          <Button id="calendar-prev-month" variant="secondary" type="button">{t('calendar.previous')}</Button>
          <Button id="calendar-next-month" variant="secondary" type="button">{t('calendar.next')}</Button>
        </div>
      </div>
      <div class="mt-6 grid grid-cols-7 gap-2 text-center text-xs font-bold uppercase tracking-[0.14em] text-[var(--color-text-soft)]" data-calendar-weekdays></div>
      <div class="mt-3 grid grid-cols-7 gap-2" data-trip-calendar-grid></div>
    </section>

    <aside class="section-shell px-6 py-6">
      <div>
        <span class="eyebrow">{t('calendar.scheduleEyebrow')}</span>
        <h2 class="mt-4 text-2xl font-black">{t('calendar.scheduleTitle')}</h2>
      </div>
      <div class="mt-6 grid gap-4" data-calendar-events></div>
    </aside>
  </Container>

  <script>
    import { mountTripCalendarPage } from '../../scripts/pages/trip-calendar';

    mountTripCalendarPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
