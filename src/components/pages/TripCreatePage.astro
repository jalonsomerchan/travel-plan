---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppBackButton from '../app/AppBackButton.astro';
import AppShell from '../app/AppShell.astro';
import DashboardSectionNav from '../app/DashboardSectionNav.astro';
import TripFormFields from '../app/TripFormFields.astro';
import Button from '../Button.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const homeUrl = getLocalizedPath('/', locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
---

<BaseLayout title={t('tripCreate.metaTitle')} description={t('tripCreate.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('tripCreate.eyebrow')}
    title={t('tripCreate.title')}
    description={t('tripCreate.description')}
    breadcrumbs={[{ label: t('nav.home'), href: homeUrl }, { label: t('dashboard.breadcrumb'), href: dashboardUrl }, { label: t('tripCreate.breadcrumb') }]}
  >
    <AppBackButton slot="topbar" fallbackHref={dashboardUrl} label={t('common.goBack')} />
    <DashboardSectionNav slot="nav" locale={locale} />
    <div slot="body" class="mt-8 border-t border-[var(--color-border)] pt-6">
      <section
        class="mb-6 rounded-[var(--radius-xl)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] px-4 py-4 shadow-[var(--shadow-xs)]"
        data-parent-trip-banner
        hidden
      >
        <p class="text-xs font-black uppercase tracking-[0.14em] text-[var(--color-text-soft)]">{t('trip.miniTrips.createEyebrow')}</p>
        <p class="mt-3 text-sm text-[var(--color-text-muted)]">
          {t('trip.miniTrips.createDescription')}
          <a class="font-bold text-[var(--color-primary)]" data-parent-trip-link href="#">
            <span data-parent-trip-name></span>
          </a>
        </p>
      </section>
      <form class="w-full space-y-4" id="trip-create-form">
        <TripFormFields locale={locale} prefix="trip-create" />
        <p class="text-sm text-[var(--color-text-soft)]" id="trip-create-message" role="status" aria-live="polite">{t('dashboard.createHint')}</p>
        <div class="flex flex-wrap gap-3">
          <Button type="submit">{t('dashboard.createAction')}</Button>
        </div>
      </form>
    </div>
  </AppShell>
  <script>
    import { mountTripCreatePage } from '../../scripts/pages/trip-create';

    mountTripCreatePage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>
