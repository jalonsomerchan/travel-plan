---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppActionsMenu from '../app/AppActionsMenu.astro';
import AppShell from '../app/AppShell.astro';
import LoadingState from '../app/LoadingState.astro';
import { type Locale } from '../../config/site';
import { getLocalizedPath, useTranslations } from '../../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const dashboardUrl = getLocalizedPath('/app/', locale);
const dashboardTitle = locale === 'es' ? 'Bienvenido a TravelPlan' : 'Welcome to TravelPlan';
---

<BaseLayout title={t('dashboard.metaTitle')} description={t('dashboard.metaDescription')} locale={locale}>
  <AppShell
    eyebrow={t('dashboard.eyebrow')}
    title={dashboardTitle}
    loading
    loadingLabel={t('common.loading')}
    breadcrumbs={[{ label: t('nav.home'), href: getLocalizedPath('/', locale) }, { label: t('dashboard.breadcrumb') }]}
  >
    <div slot="topbar" class="app-shell-topbar-row">
      <span></span>
      <AppActionsMenu
        ariaLabel={t('dashboard.breadcrumb')}
        label="..."
        items={[
          { href: dashboardUrl, id: 'dashboard-invites-link', label: t('dashboard.goInvites') },
          { href: dashboardUrl, id: 'dashboard-create-trip-link', label: t('dashboard.goCreateTrip') },
          { href: dashboardUrl, id: 'sign-out-button', label: t('auth.signOut') },
        ]}
      />
    </div>
    <div slot="body" class="mt-8 border-t border-[var(--color-border)] pt-6">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <span class="eyebrow">{t('dashboard.listEyebrow')}</span>
          <h2 class="mt-4 text-2xl font-black">{t('dashboard.listTitle')}</h2>
        </div>
        <div class="grid w-full grid-cols-3 gap-2 sm:gap-3" data-dashboard-stats></div>
      </div>
      <div class="mt-6 grid gap-4" data-trip-list>
        <LoadingState label={t('common.loading')} />
      </div>
    </div>
  </AppShell>

  <script>
    import { mountDashboardPage } from '../../scripts/pages/dashboard';

    mountDashboardPage({ locale: document.documentElement.lang });
  </script>
</BaseLayout>