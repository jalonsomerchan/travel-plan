---
const {
  href,
  variant = 'primary',
  class: className = '',
  ...attrs
} = Astro.props;

const classes = [
  'inline-flex items-center justify-center rounded-lg px-4 py-2 text-sm font-semibold transition',
  variant === 'secondary'
    ? 'border border-[var(--color-border)] bg-white text-[var(--color-text)] hover:bg-gray-50'
    : 'bg-[var(--color-primary)] text-white hover:opacity-90',
  className,
];
---

{href ? (
  <a href={href} class:list={classes} {...attrs}>
    <slot />
  </a>
) : (
  <button class:list={classes} {...attrs}>
    <slot />
  </button>
)}
