---
import Container from '../Container.astro';
import Breadcrumbs from './Breadcrumbs.astro';
import LoadingState from './LoadingState.astro';
import TripContextHeader from './TripContextHeader.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  breadcrumbs?: Array<{ href?: string; label: string; key?: string }>;
  loading?: boolean;
  loadingLabel?: string;
  compactTop?: boolean;
  tripContext?: boolean;
  tripContextName?: string;
}

const {
  title,
  description,
  breadcrumbs = [],
  loading = false,
  loadingLabel = 'Loading',
  compactTop = false,
  tripContext = false,
  tripContextName = '',
} = Astro.props;
const containerClass = compactTop ? 'pt-3 pb-8 md:pt-4 md:pb-12' : 'py-8 md:py-12';
const shellClasses = [
  'section-shell px-6 md:px-10',
  compactTop ? 'app-shell--compact-top py-5 md:py-6' : 'py-7 md:py-8',
];
const shouldStartAtDashboard =
  breadcrumbs.length > 1 && Boolean(breadcrumbs[1]?.href?.endsWith('/app/'));
const visibleBreadcrumbs = shouldStartAtDashboard ? breadcrumbs.slice(1) : breadcrumbs;
---

<Container class={containerClass}>
  <div class="app-shell-topbar">
    <slot name="topbar" />
  </div>
  <section class:list={shellClasses}>
    {visibleBreadcrumbs.length > 0 && <Breadcrumbs items={visibleBreadcrumbs} />}
    {loading && <LoadingState class="app-loading-screen" label={loadingLabel} data-app-loading />}
    <div data-app-content={loading ? 'loading' : undefined} hidden={loading}>
      <div class="app-shell-layout">
        <div class="app-shell-copy">
          {tripContext && (
            <TripContextHeader tripName={tripContextName}>
              <slot name="trip-context-action" />
            </TripContextHeader>
          )}
          <h1 class="app-shell-title" data-app-title>{title}</h1>
          {description && (
            <p class="app-shell-description prose-copy" data-app-description>
              {description}
            </p>
          )}
          <div class="app-shell-meta" data-app-meta hidden></div>
        </div>
        {!tripContext && (
          <div class="app-shell-side">
            <slot />
          </div>
        )}
      </div>
      <slot name="nav" />
      <slot name="body" />
    </div>
  </section>
</Container>
