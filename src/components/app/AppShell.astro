---
import Container from '../Container.astro';

interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<Container class="py-8 md:py-12">
  <section class="section-shell overflow-hidden px-6 py-8 md:px-10 md:py-10">
    <div class="max-w-3xl">
      <span class="eyebrow">{eyebrow}</span>
      <h1 class="mt-5 text-3xl font-black tracking-tight text-[var(--color-text)] md:text-5xl">{title}</h1>
      <p class="prose-copy mt-4 max-w-2xl text-base md:text-lg">{description}</p>
    </div>
    <slot />
  </section>
</Container>
