---
interface Item {
  href?: string;
  label: string;
  key?: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-2.5 text-sm text-[var(--color-text-soft)]">
    {items.map((item, index) => (
      <>
        <li>
          {item.href && index < items.length - 1 ? (
            <a
              class="inline-flex items-center rounded-full px-2.5 py-1.5 transition hover:bg-[var(--color-surface-soft)] hover:text-[var(--color-text)]"
              href={item.href}
              data-breadcrumb-key={item.key}
            >
              {item.label}
            </a>
          ) : (
            <span
              class="inline-flex items-center rounded-full bg-[var(--color-surface-soft)] px-2.5 py-1.5 font-semibold text-[var(--color-text)]"
              data-breadcrumb-key={item.key}
            >
              {item.label}
            </span>
          )}
        </li>
        {index < items.length - 1 && <li aria-hidden="true" class="text-[var(--color-text-soft)]/70">›</li>}
      </>
    ))}
  </ol>
</nav>
