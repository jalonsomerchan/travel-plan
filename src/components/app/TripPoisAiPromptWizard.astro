---
import { tripPoiAiPromptTypeValues } from '../../lib/app/trip-pois-ai-prompt-wizard';
import type { Locale } from '../../config/site';
import { useTranslations } from '../../i18n/ui';
import Button from '../Button.astro';
import LocationPickerFields from './LocationPickerFields.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const steps = [
  t('tripPoisAiPrompt.wizard.placeStep'),
  t('tripPoisAiPrompt.wizard.typeStep'),
  t('tripPoisAiPrompt.wizard.promptStep'),
  t('tripPoisAiPrompt.wizard.importStep'),
];
---

<section class="space-y-5 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-4 md:p-6" aria-labelledby="trip-pois-ai-prompt-wizard-title">
  <div>
    <span class="eyebrow">{t('tripPoisAiPrompt.wizard.eyebrow')}</span>
    <h2 class="mt-3 text-2xl font-black text-[var(--color-text)]" id="trip-pois-ai-prompt-wizard-title">{t('tripPoisAiPrompt.wizard.title')}</h2>
    <p class="mt-3 text-sm font-semibold text-[var(--color-text-soft)]" data-trip-pois-ai-prompt-step-progress>
      {t('tripPoisAiPrompt.wizard.stepProgress').replace('{current}', '1').replace('{total}', String(steps.length))}
    </p>
  </div>

  <div class="-mx-4 overflow-x-auto px-4 pb-1 md:mx-0 md:px-0" aria-label={t('tripPoisAiPrompt.wizard.stepsLabel')}>
    <div class="flex min-w-max gap-3 md:min-w-0">
      {steps.map((label, index) => (
        <article class="wizard-step-chip min-w-32 px-3 py-2 text-xs md:min-w-0 md:text-sm" data-trip-pois-ai-prompt-step-chip data-active={index === 0 ? 'true' : 'false'}>
          <span class="wizard-step-chip-index">{index + 1}</span>
          <strong class="wizard-step-chip-label whitespace-nowrap md:whitespace-normal">{label}</strong>
        </article>
      ))}
    </div>
  </div>

  <div class="space-y-5" id="trip-pois-ai-prompt-wizard">
    <section class="space-y-4" data-trip-pois-ai-prompt-step="0">
      <div>
        <h3 class="text-xl font-black text-[var(--color-text)]">{t('tripPoisAiPrompt.wizard.placeTitle')}</h3>
        <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripPoisAiPrompt.wizard.placeHelper')}</p>
      </div>

      <LocationPickerFields
        clearButtonName={t('tripPoisAiPrompt.wizard.placeClear')}
        helperKey="tripPoisAiPrompt.wizard.placeFieldHelper"
        latFieldName="placeLat"
        locale={locale}
        lngFieldName="placeLng"
        nameFieldName="placeName"
        prefix="trip-pois-ai-prompt"
        queryFieldLabel={t('tripPoisAiPrompt.wizard.place')}
        queryFieldName="placeQuery"
        queryPlaceholder={t('tripPoisAiPrompt.wizard.placePlaceholder')}
        searchButtonName={t('tripPoisAiPrompt.wizard.placeSearch')}
        useCurrentLocationName={t('tripPoisAiPrompt.wizard.placeCurrent')}
      />
    </section>

    <section class="space-y-4" data-trip-pois-ai-prompt-step="1" hidden>
      <div>
        <h3 class="text-xl font-black text-[var(--color-text)]">{t('tripPoisAiPrompt.wizard.typeTitle')}</h3>
        <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripPoisAiPrompt.wizard.typeHelper')}</p>
      </div>

      <label class="grid gap-2">
        <span class="field-label">{t('tripPoisAiPrompt.wizard.type')}</span>
        <select class="field-input" name="type">
          {tripPoiAiPromptTypeValues.map((type) => (
            <option value={type}>{t(`tripPois.type.${type}`)}</option>
          ))}
        </select>
      </label>
    </section>

    <section class="space-y-4" data-trip-pois-ai-prompt-step="2" hidden>
      <div>
        <h3 class="text-xl font-black text-[var(--color-text)]">{t('tripPoisAiPrompt.wizard.promptTitle')}</h3>
        <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripPoisAiPrompt.wizard.promptHelper')}</p>
      </div>

      <label class="field-label" for="trip-pois-ai-prompt-output">{t('tripPoisAiPrompt.prompt.label')}</label>
      <textarea class="field-input min-h-72 font-mono text-sm" data-trip-pois-ai-prompt-output id="trip-pois-ai-prompt-output" readonly></textarea>
      <div class="flex flex-wrap gap-3">
        <Button data-trip-pois-ai-prompt-copy type="button">{t('tripPoisAiPrompt.prompt.copy')}</Button>
        <Button data-trip-pois-ai-prompt-chatgpt href="https://chatgpt.com/" rel="noopener noreferrer" target="_blank" variant="secondary">{t('tripPoisAiPrompt.prompt.openChatGpt')}</Button>
      </div>
      <p class="text-sm text-[var(--color-text-soft)]" data-trip-pois-ai-prompt-message>{t('tripPoisAiPrompt.prompt.helper')}</p>
    </section>

    <section class="space-y-4" data-trip-pois-ai-prompt-step="3" hidden>
      <div>
        <h3 class="text-xl font-black text-[var(--color-text)]">{t('tripPoisAiPrompt.wizard.importTitle')}</h3>
        <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripPoisAiPrompt.wizard.importHelper')}</p>
      </div>

      <form class="space-y-4" data-trip-pois-ai-import-form>
        <label class="grid gap-2">
          <span class="field-label">{t('tripPoisAiPrompt.import.label')}</span>
          <textarea class="field-input min-h-60 font-mono text-sm" name="json" placeholder={t('tripPoisAiPrompt.import.placeholder')}></textarea>
        </label>
        <div class="flex flex-wrap gap-3">
          <Button type="submit">{t('tripPoisAiPrompt.import.action')}</Button>
        </div>
      </form>
      <p class="text-sm text-[var(--color-text-soft)]" data-trip-pois-ai-import-message>{t('tripPoisAiPrompt.import.helper')}</p>
    </section>
  </div>

  <p class="text-sm text-[var(--color-text-soft)]" id="trip-pois-ai-prompt-wizard-message">{t('tripPoisAiPrompt.wizard.helper')}</p>

  <div class="flex flex-wrap gap-3">
    <Button class="min-w-0 flex-1" id="trip-pois-ai-prompt-prev-step" type="button" variant="ghost">{t('tripAi.form.previous')}</Button>
    <Button class="min-w-0 flex-1" id="trip-pois-ai-prompt-next-step" type="button" variant="secondary">{t('tripAi.form.next')}</Button>
  </div>
</section>
