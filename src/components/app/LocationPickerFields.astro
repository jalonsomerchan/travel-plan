---
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../config/site';

interface Props {
  clearButtonName: string;
  helperKey?: string;
  latFieldName: string;
  locale: Locale;
  lngFieldName: string;
  nameFieldName: string;
  prefix: string;
  queryFieldLabel: string;
  queryFieldName: string;
  queryPlaceholder?: string;
  rootTestId?: string;
  searchButtonName: string;
}

const {
  clearButtonName,
  helperKey = 'plan.location.helper',
  latFieldName,
  locale,
  lngFieldName,
  nameFieldName,
  prefix,
  queryFieldLabel,
  queryFieldName,
  queryPlaceholder,
  rootTestId,
  searchButtonName,
} = Astro.props;
const t = useTranslations(locale);
---

<section
  class="space-y-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-4"
  data-location-picker
  data-empty-query-label={t('plan.location.emptyQuery')}
  data-initialized-field-label={queryFieldLabel}
  data-no-results-label={t('plan.location.noResults')}
  data-search-error-label={t('plan.location.searchError')}
  data-searching-label={t('plan.location.searching')}
  data-selected-label={t('plan.location.selected')}
  data-results-id={`${prefix}-location-results`}
  data-testid={rootTestId}
  data-unnamed-label={t('plan.location.unnamed')}
>
  <div>
    <label class="field-label" for={`${prefix}-location-query`}>{queryFieldLabel}</label>
    <div class="relative">
      <div class="flex flex-col gap-3 sm:flex-row">
        <div class="relative flex-1">
          <input
            aria-autocomplete="list"
            aria-controls={`${prefix}-location-results`}
            aria-expanded="false"
            autocomplete="off"
            class="field-input"
            id={`${prefix}-location-query`}
            name={queryFieldName}
            placeholder={queryPlaceholder ?? t('plan.location.placeholder')}
            role="combobox"
            type="search"
            data-location-query
          />
        </div>
        <button
          class="inline-flex items-center justify-center rounded-full bg-[var(--color-secondary)] px-4 py-2.5 text-sm font-semibold text-white shadow-[var(--shadow-xs)] transition hover:opacity-90"
          type="button"
          data-location-search-button
        >
          {searchButtonName}
        </button>
      </div>
      <div
        class="absolute left-0 right-0 top-[calc(100%+0.75rem)] z-20 max-h-72 overflow-auto rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] p-3 text-sm text-[var(--color-text-muted)] shadow-[var(--shadow-md)]"
        hidden
        id={`${prefix}-location-results`}
        role="listbox"
        aria-label={queryFieldLabel}
        data-location-search-results
      >
        {t('plan.location.initialState')}
      </div>
    </div>
    <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t(helperKey)}</p>
  </div>
  <div class="overflow-hidden rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)]">
    <div class="plan-location-map" data-location-map></div>
  </div>
  <div class="space-y-3">
    <div class="rounded-[var(--radius-md)] border border-[var(--color-border)] bg-[var(--color-surface-raised)] p-3 text-sm text-[var(--color-text-muted)]" data-location-selected-summary>
      {t('plan.location.noneSelected')}
    </div>
    <button
      class="inline-flex rounded-full border border-[var(--color-border)] px-4 py-2 text-sm font-semibold text-[var(--color-text)] transition hover:bg-[var(--color-surface-raised)]"
      type="button"
      data-location-clear-button
    >
      {clearButtonName}
    </button>
  </div>
  <input type="hidden" name={nameFieldName} data-location-name />
  <input type="hidden" name={latFieldName} data-location-lat />
  <input type="hidden" name={lngFieldName} data-location-lng />
</section>
