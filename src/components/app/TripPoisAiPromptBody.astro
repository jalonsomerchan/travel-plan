---
import type { Locale } from '../../config/site';
import { useTranslations } from '../../i18n/ui';
import Button from '../Button.astro';
import LoadingState from './LoadingState.astro';
import TripPoisAiPromptWizard from './TripPoisAiPromptWizard.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<div class="space-y-8 pt-6">
  <TripPoisAiPromptWizard locale={locale} />

  <section class="space-y-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-4 md:p-5" aria-labelledby="trip-pois-ai-prompt-output-title">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <span class="eyebrow">{t('tripPoisAiPrompt.prompt.eyebrow')}</span>
        <h2 class="mt-3 text-2xl font-black text-[var(--color-text)]" id="trip-pois-ai-prompt-output-title">{t('tripPoisAiPrompt.prompt.title')}</h2>
      </div>
    </div>
    <label class="field-label" for="trip-pois-ai-prompt-output">{t('tripPoisAiPrompt.prompt.label')}</label>
    <textarea class="field-input min-h-72 font-mono text-sm" data-trip-pois-ai-prompt-output id="trip-pois-ai-prompt-output" readonly></textarea>
    <div class="flex flex-wrap gap-3">
      <Button data-trip-pois-ai-prompt-copy type="button">{t('tripPoisAiPrompt.prompt.copy')}</Button>
      <Button data-trip-pois-ai-prompt-chatgpt href="https://chatgpt.com/" rel="noopener noreferrer" target="_blank" variant="secondary">{t('tripPoisAiPrompt.prompt.openChatGpt')}</Button>
    </div>
    <p class="text-sm text-[var(--color-text-soft)]" data-trip-pois-ai-prompt-message>{t('tripPoisAiPrompt.prompt.helper')}</p>
  </section>

  <section class="space-y-4 rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface)] p-4 md:p-5">
    <div>
      <span class="eyebrow">{t('tripPoisAiPrompt.import.eyebrow')}</span>
      <h2 class="mt-3 text-2xl font-black text-[var(--color-text)]">{t('tripPoisAiPrompt.import.title')}</h2>
      <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('tripPoisAiPrompt.import.description')}</p>
    </div>
    <form class="space-y-4" data-trip-pois-ai-import-form>
      <label class="grid gap-2">
        <span class="field-label">{t('tripPoisAiPrompt.import.label')}</span>
        <textarea class="field-input min-h-60 font-mono text-sm" name="json" placeholder={t('tripPoisAiPrompt.import.placeholder')}></textarea>
      </label>
      <div class="flex flex-wrap gap-3">
        <Button type="submit">{t('tripPoisAiPrompt.import.action')}</Button>
      </div>
    </form>
    <p class="text-sm text-[var(--color-text-soft)]" data-trip-pois-ai-import-message>{t('tripPoisAiPrompt.import.helper')}</p>
  </section>

  <section class="border-t border-[var(--color-border)] pt-8" aria-labelledby="trip-pois-ai-candidates-title" data-trip-pois-ai-candidates-section hidden>
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <span class="eyebrow">{t('tripPoisAiPrompt.candidates.eyebrow')}</span>
        <h2 class="mt-3 text-2xl font-black text-[var(--color-text)]" id="trip-pois-ai-candidates-title">{t('tripPoisAiPrompt.candidates.title')}</h2>
      </div>
      <span class="status-pill" data-trip-pois-ai-candidates-count data-tone="warning">0</span>
    </div>
    <div class="mt-5 grid gap-4" data-trip-pois-ai-candidates-list>
      <LoadingState label={t('common.loading')} />
    </div>
    <div class="mt-5 flex flex-wrap gap-3" data-trip-pois-ai-candidates-actions hidden>
      <Button data-trip-pois-ai-save-selected type="button">{t('tripPoisAiPrompt.candidates.saveSelected')}</Button>
    </div>
  </section>
</div>
