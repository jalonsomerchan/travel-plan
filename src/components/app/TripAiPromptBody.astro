---
import type { Locale } from '../../config/site';
import { useTranslations } from '../../i18n/ui';
import Button from '../Button.astro';
import LoadingState from './LoadingState.astro';
import TripAiPromptWizard from './TripAiPromptWizard.astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<div class="space-y-8 pt-6">
  <TripAiPromptWizard locale={locale} />

  <section class="border-t border-[var(--color-border)] pt-8" aria-labelledby="trip-ai-candidates-title">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <span class="eyebrow">{t('tripAiPrompt.candidates.eyebrow')}</span>
        <h2 class="mt-3 text-2xl font-black text-[var(--color-text)]" id="trip-ai-candidates-title">
          {t('tripAiPrompt.candidates.title')}
        </h2>
      </div>
      <span class="status-pill" data-trip-ai-candidates-count data-tone="warning">0</span>
    </div>
    <div class="mt-5 grid gap-4" data-trip-ai-candidates-list>
      <LoadingState label={t('common.loading')} />
    </div>
    <div class="mt-5 flex flex-wrap gap-3" data-trip-ai-candidates-actions hidden>
      <Button data-trip-ai-save-selected type="button">{t('tripAiPrompt.candidates.saveSelected')}</Button>
    </div>
  </section>
</div>
