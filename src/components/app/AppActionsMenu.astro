---
interface ActionItem {
  href: string;
  id?: string;
  label: string;
}

interface Props {
  ariaLabel?: string;
  label: string;
  items: ActionItem[];
}

const { ariaLabel, label, items } = Astro.props;
---

<details class="app-actions-menu">
  <summary aria-label={ariaLabel} class="app-actions-menu-trigger" title={ariaLabel}>
    {label}
  </summary>
  <div class="app-actions-menu-panel">
    {items.map((item) => (
      <a class="app-actions-menu-link" href={item.href} id={item.id}>
        {item.label}
      </a>
    ))}
  </div>
</details>
