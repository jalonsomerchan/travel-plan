---
interface ActionItem {
  href: string;
  id?: string;
  label: string;
}

interface Props {
  ariaLabel?: string;
  label: string;
  items: ActionItem[];
}

const { ariaLabel, label, items } = Astro.props;
---

<details class="app-actions-menu">
  <summary aria-label={ariaLabel} class="app-actions-menu-trigger" title={ariaLabel}>
    {label}
  </summary>
  <div class="app-actions-menu-panel">
    {items.map((item) => (
      <a class="app-actions-menu-link" href={item.href} id={item.id}>
        {item.label}
      </a>
    ))}
  </div>
</details>

<style is:global>
  .section-shell:has(.app-actions-menu[open]) {
    position: relative;
    z-index: 40;
    overflow: visible;
  }

  .app-shell-topbar {
    position: relative;
    z-index: 30;
  }

  .app-actions-menu[open] {
    z-index: 50;
  }

  .app-actions-menu-panel {
    z-index: 60;
  }
</style>