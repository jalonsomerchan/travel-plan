---
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../config/site';

interface Props {
  locale: Locale;
  prefix: string;
  translationPrefix?: 'tripChecklist' | 'tripLuggage';
}

const { locale, prefix, translationPrefix = 'tripChecklist' } = Astro.props;
const t = useTranslations(locale);
---

<div class="space-y-4">
  <div>
    <label class="field-label" for={`${prefix}-title`}>{t(`${translationPrefix}.form.title`)}</label>
    <input
      class="field-input"
      id={`${prefix}-title`}
      name="title"
      placeholder={t(`${translationPrefix}.form.placeholder`)}
      required
    />
  </div>
</div>
