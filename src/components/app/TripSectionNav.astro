---
import type { Locale } from '../../config/site';
import { useTranslations } from '../../i18n/ui';
import AppSectionNav from './AppSectionNav.astro';

interface Props {
  fallbackHref: string;
  locale: Locale;
}

const { fallbackHref, locale } = Astro.props;
const t = useTranslations(locale);
---

<AppSectionNav
  ariaLabel={t('trip.actionsMenu')}
  items={[
    { href: fallbackHref, id: 'trip-plans-link', label: t('appNav.plans') },
    { href: fallbackHref, id: 'trip-checklist-link', label: t('tripChecklist.goChecklist') },
    { href: fallbackHref, hidden: true, id: 'trip-luggage-link', label: t('tripLuggage.goLuggage') },
    { href: fallbackHref, id: 'trip-weather-link', label: t('weather.navLabel') },
    { href: fallbackHref, id: 'trip-calendar-link', label: t('calendar.breadcrumb') },
    { href: fallbackHref, id: 'trip-map-link', label: t('map.breadcrumb') },
    { href: fallbackHref, id: 'trip-pois-link', label: t('tripPois.breadcrumb') },
  ]}
/>
