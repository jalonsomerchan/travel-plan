---
import LocationPickerFields from './LocationPickerFields.astro';
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../config/site';

interface Props {
  locale: Locale;
  prefix: string;
}

const { locale, prefix } = Astro.props;
const t = useTranslations(locale);
---

<LocationPickerFields
  clearButtonName={t('plan.location.clear')}
  latFieldName="locationLat"
  locale={locale}
  lngFieldName="locationLng"
  nameFieldName="locationName"
  prefix={prefix}
  queryFieldLabel={t('plan.form.location')}
  queryFieldName="locationQuery"
  searchButtonName={t('plan.location.search')}
/>
