---
import AccommodationFormFields from './AccommodationFormFields.astro';
import LocationPickerFields from './LocationPickerFields.astro';
import { useTranslations } from '../../i18n/ui';
import type { Locale } from '../../config/site';
import { tripStatusValues } from '../../lib/app/models';

interface Props {
  locale: Locale;
  prefix: string;
}

const { locale, prefix } = Astro.props;
const t = useTranslations(locale);
---

<div class="grid gap-5 xl:grid-cols-[minmax(0,1.1fr)_minmax(22rem,0.9fr)] xl:items-start" data-trip-form-layout>
  <div class="space-y-5">
    <section class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-4 md:p-5">
      <div class="mb-4">
        <h2 class="text-base font-black text-[var(--color-text)]">{t('trip.form.sectionBasics')}</h2>
        <p class="mt-1 text-sm text-[var(--color-text-soft)]">{t('trip.form.sectionBasicsHelp')}</p>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="md:col-span-2">
          <label class="field-label" for={`${prefix}-name`}>{t('trip.form.name')}</label>
          <input class="field-input" id={`${prefix}-name`} name="name" required />
        </div>
        <div>
          <label class="field-label" for={`${prefix}-start-date`}>{t('trip.form.startDate')}</label>
          <input class="field-input" id={`${prefix}-start-date`} name="startDate" type="date" />
        </div>
        <div>
          <label class="field-label" for={`${prefix}-end-date`}>{t('trip.form.endDate')}</label>
          <input class="field-input" id={`${prefix}-end-date`} name="endDate" type="date" />
        </div>
        <div class="md:col-span-2">
          <label class="field-label" for={`${prefix}-status`}>{t('trip.form.status')}</label>
          <select class="field-select" id={`${prefix}-status`} name="status">
            {tripStatusValues.map((status) => (
              <option value={status}>{t(`status.trip.${status}`)}</option>
            ))}
          </select>
          <p class="mt-2 text-sm text-[var(--color-text-soft)]">{t('trip.form.statusHelp')}</p>
        </div>
      </div>
    </section>

    <section class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-4 md:p-5">
      <div class="mb-4">
        <h2 class="text-base font-black text-[var(--color-text)]">{t('trip.form.sectionDestination')}</h2>
        <p class="mt-1 text-sm text-[var(--color-text-soft)]">{t('trip.form.sectionDestinationHelp')}</p>
      </div>
      <LocationPickerFields
        clearButtonName={t('trip.form.locationClear')}
        helperKey="trip.form.locationHelper"
        latFieldName="locationLat"
        locale={locale}
        lngFieldName="locationLng"
        nameFieldName="location"
        prefix={`${prefix}-location`}
        queryFieldLabel={t('trip.form.location')}
        queryFieldName="locationQuery"
        required
        searchButtonName={t('plan.location.search')}
      />
    </section>
  </div>

  <aside class="space-y-5 xl:sticky xl:top-24" data-trip-form-sidebar>
    <section class="rounded-[var(--radius-lg)] border border-[var(--color-border)] bg-[var(--color-surface-soft)] p-4 md:p-5">
      <div class="mb-4">
        <span class="eyebrow">{t('accommodation.sectionEyebrow')}</span>
        <h2 class="mt-3 text-base font-black text-[var(--color-text)]">{t('accommodation.sectionTitle')}</h2>
        <p class="mt-1 text-sm text-[var(--color-text-soft)]">{t('trip.form.sectionAccommodationHelp')}</p>
      </div>
      <AccommodationFormFields locale={locale} prefix={prefix} />
    </section>
  </aside>
</div>
