---
import '../styles/global.css';
import '../styles/pwa-status.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PwaConnectionStatus from '../components/PwaConnectionStatus.astro';
import { defaultLocale, siteConfig, type Locale } from '../config/site';
import { useTranslations } from '../i18n/ui';
import { getAbsoluteUrl, stripBasePath, withBasePath } from '../utils/paths';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  locale?: Locale;
}

const {
  title = siteConfig.name,
  image = 'og-image.svg',
  locale = defaultLocale,
} = Astro.props;

const t = useTranslations(locale);
const description = Astro.props.description ?? t('site.description');
const pageTitle = title === siteConfig.name ? title : `${title} · ${siteConfig.name}`;
const routePath = stripBasePath(Astro.url.pathname);
const canonicalUrl = getAbsoluteUrl(withBasePath(routePath), siteConfig.url);
const imageUrl = getAbsoluteUrl(withBasePath(image), siteConfig.url);
const ogLocale = locale === 'es' ? 'es_ES' : 'en_US';
const themeScript = `
  (() => {
    const storedTheme = localStorage.getItem('travelplan-theme');
    const systemTheme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    document.documentElement.dataset.theme = storedTheme ?? systemTheme;
  })();
`;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href={withBasePath('favicon.svg')} />
    <link rel="icon" href={withBasePath('favicon.ico')} />
    <link rel="manifest" href={withBasePath('manifest.webmanifest')} />
    <meta name="theme-color" content="#2563eb" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content={siteConfig.name} />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <script is:inline set:html={themeScript}></script>
  </head>
  <body>
    <Header locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
    <PwaConnectionStatus locale={locale} />
    <script>
      import { registerServiceWorker } from '../scripts/pwa/register-service-worker';

      registerServiceWorker();
    </script>
  </body>
</html>
