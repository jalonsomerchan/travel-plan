---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import Container from '../components/Container.astro';
import { defaultLocale } from '../config/site';
import { getLocalizedPath, useTranslations } from '../i18n/ui';

const locale = defaultLocale;
const t = useTranslations(locale);
const homeUrl = getLocalizedPath('/', locale);
---

<BaseLayout title={t('notFound.title')} description={t('notFound.description')} locale={locale}>
  <Container class="py-20 text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] text-[var(--color-primary)]">{t('notFound.eyebrow')}</p>
    <h1 class="mt-3 text-4xl font-black tracking-tight">{t('notFound.title')}</h1>
    <p class="mx-auto mt-4 max-w-xl text-[var(--color-muted)]">
      {t('notFound.message')}
    </p>
    <div class="mt-8">
      <Button href={homeUrl}>{t('notFound.backHome')}</Button>
    </div>
  </Container>
</BaseLayout>
